@page "/kommune"
@rendermode InteractiveServer
@inject DarRuntime Runtime
@inject IJSRuntime Js
@implements IAsyncDisposable

<PageTitle>Kommune</PageTitle>

<div class="page">
    <header class="page-header">
        <h1>Kommune</h1>
        <p>
            Test af <code>Dar.Kommune</code> — liste og opslag ud fra browser-koordinater.
            Datafordeler <a href="https://confluence.sdfi.dk/pages/viewpage.action?pageId=199984259" target="_blank" rel="noopener">DAGI GraphQL</a>
            forsøges først; ved tomme svar bruges
            <a href="https://dawadocs.dataforsyningen.dk/dok/api/kommune" target="_blank" rel="noopener">DAWA</a>
            (gratis, ingen API-nøgle).
        </p>
        <p class="section-intro">
            Kommune-listen caches i 24 timer. Koordinat-opslag bruger DAWA reverse geocoding når GraphQL er tom.
            Fanen <strong>Datafordeler-only</strong> kalder kun GraphQL + REST DAGI (ingen DAWA).
        </p>
    </header>

    @if (!string.IsNullOrWhiteSpace(_configurationError))
    {
        <section class="alert alert--warning">
            <strong>Konfiguration:</strong> @_configurationError
        </section>
    }
    else
    {
        <section class="card">
            <div class="tab-bar tab-bar--3" role="tablist" aria-label="Kommunevalg">
                <button type="button"
                        class="tab @(_mode == SelectionMode.List ? "tab--active" : null)"
                        role="tab"
                        aria-selected="@(_mode == SelectionMode.List)"
                        @onclick="() => _mode = SelectionMode.List">
                    Kommune
                </button>
                <button type="button"
                        class="tab @(_mode == SelectionMode.Location ? "tab--active" : null)"
                        role="tab"
                        aria-selected="@(_mode == SelectionMode.Location)"
                        @onclick="() => _mode = SelectionMode.Location">
                    Din lokation
                </button>
                <button type="button"
                        class="tab @(_mode == SelectionMode.DatafordelerOnly ? "tab--active" : null)"
                        role="tab"
                        aria-selected="@(_mode == SelectionMode.DatafordelerOnly)"
                        @onclick="() => _mode = SelectionMode.DatafordelerOnly">
                    Datafordeler-only
                </button>
            </div>

            @if (_mode == SelectionMode.List)
            {
                <div class="tab-panel" role="tabpanel">
                    <h2>Vælg kommune</h2>
                    <p class="section-intro">Henter alle kommuner med <code>GetAllAsync()</code>.</p>

                    <div class="actions actions--inline">
                        <button type="button"
                                class="button button--primary"
                                disabled="@_isLoadingList"
                                @onclick="LoadKommunerAsync">
                            @(_isLoadingList ? "Henter..." : "Hent kommuner")
                        </button>
                        @if (_kommuner.Count > 0)
                        {
                            <span class="meta-pill">@_kommuner.Count kommuner</span>
                        }
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_listMethodCall))
                    {
                        <MethodCallHint Text="@_listMethodCall" />
                    }

                    @if (_kommuner.Count > 0)
                    {
                        <label class="kommune-select">
                            Vælg kommune
                            <select class="input"
                                    value="@_selectedKommuneId"
                                    @onchange="OnKommuneSelected">
                                <option value="">— Vælg —</option>
                                @foreach (var kommune in _kommuner)
                                {
                                    <option value="@kommune.IdLokalId">@kommune.Navn (@kommune.Kommunekode)</option>
                                }
                            </select>
                        </label>
                    }
                </div>
            }
            else if (_mode == SelectionMode.Location)
            {
                <div class="tab-panel" role="tabpanel">
                    <h2>Din lokation</h2>
                    <p class="section-intro">
                        Bruger browserens geolocation (WGS84 latitude/longitude) og kalder
                        <code>FindByCoordinatesAsync()</code>.
                    </p>

                    <div class="actions">
                        <button type="button"
                                class="button button--primary"
                                disabled="@_isResolvingLocation"
                                @onclick="ResolveLocationAsync">
                            @(_isResolvingLocation ? "Finder kommune..." : "Brug min position")
                        </button>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_locationMethodCall))
                    {
                        <MethodCallHint Text="@_locationMethodCall" />
                    }

                    @RenderCoordinatesSummary(_latitude, _longitude, _accuracyMeters)
                </div>
            }
            else
            {
                <div class="tab-panel" role="tabpanel">
                    <h2>Datafordeler-only</h2>
                    <p class="section-intro">
                        Kalder <code>FindByCoordinatesDatafordelerAsync()</code> — GraphQL + REST DAGI, <strong>ingen DAWA</strong>.
                        Returnerer repræsentativt punkt når DAGI-geometri er tilgængelig.
                    </p>

                    <div class="form-grid form-grid--compact">
                        <label>
                            Latitude (WGS84)
                            <InputText @bind-Value="_dfLatitudeInput" class="input" placeholder="56.02304649121056" />
                        </label>
                        <label>
                            Longitude (WGS84)
                            <InputText @bind-Value="_dfLongitudeInput" class="input" placeholder="12.598664281911976" />
                        </label>
                    </div>

                    <div class="actions actions--inline">
                        <button type="button"
                                class="button button--primary"
                                disabled="@_isResolvingDatafordeler"
                                @onclick="ResolveDatafordelerAsync">
                            @(_isResolvingDatafordeler ? "Finder..." : "Slå op")
                        </button>
                        <button type="button"
                                class="button"
                                disabled="@_isResolvingDatafordeler"
                                @onclick="UseHelsingoerTestPoint">
                            Testpunkt (Helsingør)
                        </button>
                        <button type="button"
                                class="button"
                                disabled="@_isResolvingDatafordeler"
                                @onclick="ResolveDatafordelerFromGeolocationAsync">
                            Brug min position
                        </button>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_datafordelerMethodCall))
                    {
                        <MethodCallHint Text="@_datafordelerMethodCall" />
                    }

                    @RenderCoordinatesSummary(_dfLatitude, _dfLongitude, _dfAccuracyMeters)
                </div>
            }
        </section>

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <section class="alert alert--error">
                <strong>Fejl:</strong> @_errorMessage
            </section>
        }

        @if (_selectedKommune is not null)
        {
            @RenderKommuneSummary("Valgt kommune", _selectedKommune)
            <ResultPanel Title="Dar.Kommune (valgt)" Subtitle="KommuneDto" MethodCall="@_selectedKommuneMethodCall" Data="_selectedKommune" Open="true" />
        }

        @if (_locationKommune is not null)
        {
            @RenderKommuneSummary("Kommune fra position", _locationKommune)
            <ResultPanel Title="Dar.Kommune.FindByCoordinatesAsync" Subtitle="KommuneDto" MethodCall="@_locationMethodCall" Data="_locationKommune" Open="true" />
        }

        @if (_datafordelerKommune is not null)
        {
            @RenderKommuneSummary("Kommune (Datafordeler-only)", _datafordelerKommune, includeRepresentativePoint: true)
            <ResultPanel Title="Dar.Kommune.FindByCoordinatesDatafordelerAsync" Subtitle="KommuneDto" MethodCall="@_datafordelerMethodCall" Data="_datafordelerKommune" Open="true" />
        }

        @if (_kommuner.Count > 0)
        {
            <ResultPanel Title="Dar.Kommune.GetAllAsync" Subtitle="@($"{_kommuner.Count} kommuner")" MethodCall="@_listMethodCall" Data="_kommuner" />
        }
    }
</div>

@code {
    private const string GetAllMethodCall =
        "var services = DarClientFactory.Create(darOptions, httpClient);\n" +
        "var kommuner = await services.Dar.Kommune.GetAllAsync();";

    private const double HelsingoerTestLatitude = 56.02304649121056;
    private const double HelsingoerTestLongitude = 12.598664281911976;

    private enum SelectionMode
    {
        List,
        Location,
        DatafordelerOnly
    }

    private sealed record GeoPosition(double Latitude, double Longitude, double Accuracy);

    private SelectionMode _mode = SelectionMode.List;
    private IReadOnlyList<KommuneDto> _kommuner = Array.Empty<KommuneDto>();
    private string? _selectedKommuneId;
    private KommuneDto? _selectedKommune;
    private KommuneDto? _locationKommune;
    private KommuneDto? _datafordelerKommune;
    private double? _latitude;
    private double? _longitude;
    private double? _accuracyMeters;
    private double? _dfLatitude;
    private double? _dfLongitude;
    private double? _dfAccuracyMeters;
    private string _dfLatitudeInput = HelsingoerTestLatitude.ToString("G17");
    private string _dfLongitudeInput = HelsingoerTestLongitude.ToString("G17");
    private string? _configurationError;
    private string? _errorMessage;
    private string? _listMethodCall;
    private string? _locationMethodCall;
    private string? _datafordelerMethodCall;
    private string? _selectedKommuneMethodCall;
    private bool _isLoadingList;
    private bool _isResolvingLocation;
    private bool _isResolvingDatafordeler;
    private IJSObjectReference? _geoModule;

    protected override void OnInitialized()
    {
        _configurationError = Runtime.ConfigurationError;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _geoModule = await Js.InvokeAsync<IJSObjectReference>("import", "./js/geolocation.js");
        }
    }

    private RenderFragment RenderCoordinatesSummary(double? latitude, double? longitude, double? accuracyMeters) => builder =>
    {
        if (latitude is null || longitude is null)
        {
            return;
        }

        builder.OpenElement(0, "dl");
        builder.AddAttribute(1, "class", "summary-grid location-grid");
        builder.OpenElement(2, "div");
        builder.OpenElement(3, "dt");
        builder.AddContent(4, "Latitude");
        builder.CloseElement();
        builder.OpenElement(5, "dd");
        builder.AddContent(6, latitude.Value.ToString("0.######"));
        builder.CloseElement();
        builder.CloseElement();
        builder.OpenElement(7, "div");
        builder.OpenElement(8, "dt");
        builder.AddContent(9, "Longitude");
        builder.CloseElement();
        builder.OpenElement(10, "dd");
        builder.AddContent(11, longitude.Value.ToString("0.######"));
        builder.CloseElement();
        builder.CloseElement();
        if (accuracyMeters is not null)
        {
            builder.OpenElement(12, "div");
            builder.OpenElement(13, "dt");
            builder.AddContent(14, "Nøjagtighed");
            builder.CloseElement();
            builder.OpenElement(15, "dd");
            builder.AddContent(16, $"±{accuracyMeters.Value.ToString("0")} m");
            builder.CloseElement();
            builder.CloseElement();
        }

        builder.CloseElement();
    };

    private RenderFragment RenderKommuneSummary(string title, KommuneDto kommune, bool includeRepresentativePoint = false) => builder =>
    {
        builder.OpenElement(0, "section");
        builder.AddAttribute(1, "class", "summary card");
        builder.OpenElement(2, "h2");
        builder.AddContent(3, title);
        builder.CloseElement();
        builder.OpenElement(4, "dl");
        builder.AddAttribute(5, "class", "summary-grid");
        builder.OpenElement(6, "div");
        builder.OpenElement(7, "dt");
        builder.AddContent(8, "Navn");
        builder.CloseElement();
        builder.OpenElement(9, "dd");
        builder.AddContent(10, kommune.Navn);
        builder.CloseElement();
        builder.CloseElement();
        builder.OpenElement(11, "div");
        builder.OpenElement(12, "dt");
        builder.AddContent(13, "Kommunekode");
        builder.CloseElement();
        builder.OpenElement(14, "dd");
        builder.AddContent(15, kommune.Kommunekode);
        builder.CloseElement();
        builder.CloseElement();
        builder.OpenElement(16, "div");
        builder.OpenElement(17, "dt");
        builder.AddContent(18, "id_lokalId");
        builder.CloseElement();
        builder.OpenElement(19, "dd");
        builder.AddContent(20, kommune.IdLokalId);
        builder.CloseElement();
        builder.CloseElement();
        if (includeRepresentativePoint)
        {
            builder.OpenElement(21, "div");
            builder.OpenElement(22, "dt");
            builder.AddContent(23, "Repræsentativt punkt");
            builder.CloseElement();
            builder.OpenElement(24, "dd");
            if (kommune.RepræsentativPunktLatitude is not null && kommune.RepræsentativPunktLongitude is not null)
            {
                builder.AddContent(25, $"{kommune.RepræsentativPunktLatitude:0.######}, {kommune.RepræsentativPunktLongitude:0.######}");
            }
            else
            {
                builder.AddContent(26, "— (DAGI-geometri ikke tilgængelig endnu)");
            }

            builder.CloseElement();
            builder.CloseElement();
        }

        builder.CloseElement();
        builder.CloseElement();
    };

    private async Task LoadKommunerAsync()
    {
        _errorMessage = null;
        _isLoadingList = true;

        try
        {
            var services = Runtime.CreateServices();
            _kommuner = await services.Dar.Kommune.GetAllAsync();
            _listMethodCall = GetAllMethodCall;
        }
        catch (DatafordelerApiException ex) when (ex.ResponseBody.Contains("DAF-AUTH-0005", StringComparison.Ordinal))
        {
            _errorMessage = BuildAuthErrorMessage();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isLoadingList = false;
        }
    }

    private void OnKommuneSelected(ChangeEventArgs args)
    {
        _selectedKommuneId = args.Value?.ToString();
        _selectedKommune = _kommuner.FirstOrDefault(k => k.IdLokalId == _selectedKommuneId);
        _selectedKommuneMethodCall = _selectedKommune is null
            ? null
            : $"// Valgt fra kommuner returneret af GetAllAsync()\n" +
              $"var kommune = kommuner.First(k => k.IdLokalId == {MethodCallFormatter.CsString(_selectedKommune.IdLokalId)});\n" +
              $"// {MethodCallFormatter.CsString(_selectedKommune.Navn)} ({MethodCallFormatter.CsString(_selectedKommune.Kommunekode)})";
        _errorMessage = null;
    }

    private async Task ResolveLocationAsync()
    {
        if (_geoModule is null)
        {
            _errorMessage = "Geolocation-modulet er ikke klar endnu. Prøv igen om et øjeblik.";
            return;
        }

        _errorMessage = null;
        _locationKommune = null;
        _isResolvingLocation = true;

        try
        {
            var position = await _geoModule.InvokeAsync<GeoPosition>("getCurrentPosition");
            _latitude = position.Latitude;
            _longitude = position.Longitude;
            _accuracyMeters = position.Accuracy;

            var services = Runtime.CreateServices();
            _locationKommune = await services.Dar.Kommune.FindByCoordinatesAsync(
                position.Latitude,
                position.Longitude);
            _locationMethodCall =
                "var services = DarClientFactory.Create(darOptions, httpClient);\n" +
                $"var kommune = await services.Dar.Kommune.FindByCoordinatesAsync(\n" +
                $"    {MethodCallFormatter.Number(position.Latitude)},\n" +
                $"    {MethodCallFormatter.Number(position.Longitude)});";
        }
        catch (JSException ex)
        {
            _errorMessage = ex.Message;
        }
        catch (DatafordelerApiException ex) when (ex.ResponseBody.Contains("DAF-AUTH-0005", StringComparison.Ordinal))
        {
            _errorMessage = BuildAuthErrorMessage();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isResolvingLocation = false;
        }
    }

    private void UseHelsingoerTestPoint()
    {
        _dfLatitudeInput = HelsingoerTestLatitude.ToString("G17");
        _dfLongitudeInput = HelsingoerTestLongitude.ToString("G17");
        _errorMessage = null;
    }

    private async Task ResolveDatafordelerAsync()
    {
        _errorMessage = null;
        _datafordelerKommune = null;
        _isResolvingDatafordeler = true;

        try
        {
            if (!TryParseCoordinate(_dfLatitudeInput, out var latitude)
                || !TryParseCoordinate(_dfLongitudeInput, out var longitude))
            {
                _errorMessage = "Latitude og longitude skal være gyldige tal (WGS84).";
                return;
            }

            _dfLatitude = latitude;
            _dfLongitude = longitude;
            _dfAccuracyMeters = null;

            var services = Runtime.CreateServices();
            _datafordelerKommune = await services.Dar.Kommune.FindByCoordinatesDatafordelerAsync(
                latitude,
                longitude);
            _datafordelerMethodCall =
                "var kommune = await services.Dar.Kommune.FindByCoordinatesDatafordelerAsync(\n" +
                $"    {MethodCallFormatter.Number(latitude)},\n" +
                $"    {MethodCallFormatter.Number(longitude)});";
        }
        catch (DatafordelerApiException ex) when (ex.ResponseBody.Contains("DAF-AUTH-0005", StringComparison.Ordinal))
        {
            _errorMessage = BuildAuthErrorMessage();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isResolvingDatafordeler = false;
        }
    }

    private async Task ResolveDatafordelerFromGeolocationAsync()
    {
        if (_geoModule is null)
        {
            _errorMessage = "Geolocation-modulet er ikke klar endnu. Prøv igen om et øjeblik.";
            return;
        }

        _errorMessage = null;
        _datafordelerKommune = null;
        _isResolvingDatafordeler = true;

        try
        {
            var position = await _geoModule.InvokeAsync<GeoPosition>("getCurrentPosition");
            _dfLatitude = position.Latitude;
            _dfLongitude = position.Longitude;
            _dfAccuracyMeters = position.Accuracy;
            _dfLatitudeInput = position.Latitude.ToString("G17");
            _dfLongitudeInput = position.Longitude.ToString("G17");

            var services = Runtime.CreateServices();
            _datafordelerKommune = await services.Dar.Kommune.FindByCoordinatesDatafordelerAsync(
                position.Latitude,
                position.Longitude);
            _datafordelerMethodCall =
                "var kommune = await services.Dar.Kommune.FindByCoordinatesDatafordelerAsync(\n" +
                $"    {MethodCallFormatter.Number(position.Latitude)},\n" +
                $"    {MethodCallFormatter.Number(position.Longitude)});";
        }
        catch (JSException ex)
        {
            _errorMessage = ex.Message;
        }
        catch (DatafordelerApiException ex) when (ex.ResponseBody.Contains("DAF-AUTH-0005", StringComparison.Ordinal))
        {
            _errorMessage = BuildAuthErrorMessage();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isResolvingDatafordeler = false;
        }
    }

    private static bool TryParseCoordinate(string input, out double value) =>
        double.TryParse(input.Trim().Replace(',', '.'), System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out value);

    private static string BuildAuthErrorMessage() =>
        "IP-adressen er ikke whitelisted i Datafordeler Administration (DAF-AUTH-0005). " +
        "Tilføj din udgående IP under https://administration.datafordeler.dk/";

    public async ValueTask DisposeAsync()
    {
        if (_geoModule is not null)
        {
            await _geoModule.DisposeAsync();
        }
    }
}
