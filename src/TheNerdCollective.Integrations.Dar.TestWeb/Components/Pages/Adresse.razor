@page "/adresse"
@rendermode InteractiveServer
@using TheNerdCollective.Integrations.Dar.TestWeb.Models
@inject DarLookupOrchestrator Orchestrator

<PageTitle>Adresse & BBR</PageTitle>

<div class="page">
    <header class="page-header">
        <h1>Adresse & BBR</h1>
        <p>Autocomplete, adresseopslag og fuld BBR-kæde via Datafordeler GraphQL.</p>
    </header>

    <section class="card">
        <h2>Adresse-autocomplete</h2>
        <p class="section-intro">
            Fri-tekst søgning via Adressevælger (<code>SearchAsync</code>).
            Vælg et forslag — opslag bruger <strong>husnummer-id</strong> (ikke DisplayName).
            Enheder (fx <code>2. tv</code>) har type <code>adresse</code> med egen LocalId og separat HusnummerId.
        </p>
        <AddressAutocomplete OnAddressSelected="ApplyAutocompleteSelectionAsync" />
    </section>

    <section class="card">
        <h2>Adresseopslag (BBR test)</h2>
        <p class="section-intro">Kører hele BBR-kæden via <code>Dar.Adresseopslag.LookupAsync</code>, <code>Dar.Husnummer.FindByAddressAsync</code> og <code>Bbr.*</code>-services. Kodeeksempler vises efter opslag.</p>
        <EditForm Model="_request" OnValidSubmit="RunLookupAsync" FormName="lookupForm">
            <DataAnnotationsValidator />

            <div class="form-grid">
                <label>
                    Vej og husnummer
                    <InputText @bind-Value="_request.StreetAndNumber" class="input" />
                </label>
                <label>
                    Postnummer
                    <InputText @bind-Value="_request.PostalCode" class="input" />
                </label>
                <label>
                    By (valgfri)
                    <InputText @bind-Value="_request.City" class="input" />
                </label>
            </div>

            <div class="actions">
                <button type="submit" class="button button--primary" disabled="@(_isLoading || _configurationError is not null)">
                    @(_isLoading ? "Henter..." : "Test alle services")
                </button>
            </div>
        </EditForm>
    </section>

    @if (!string.IsNullOrWhiteSpace(_configurationError))
    {
        <section class="alert alert--warning">
            <strong>Konfiguration:</strong> @_configurationError
        </section>
    }

    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <section class="alert alert--error">
            <strong>Fejl:</strong> @_errorMessage
        </section>
    }

    @if (_result is not null)
    {
        <section class="summary card">
            <h2>Opsummering</h2>
            <dl class="summary-grid">
                <div>
                    <dt>Varighed</dt>
                    <dd>@_result.Duration.TotalMilliseconds.ToString("0") ms</dd>
                </div>
                <div>
                    <dt>Adresse</dt>
                    <dd>@_result.Adresseopslag?.Adgangsadresse</dd>
                </div>
                <div>
                    <dt>DAR id_lokalId</dt>
                    <dd>@_result.Adresseopslag?.Dar.Husnummer.IdLokalId</dd>
                </div>
                <div>
                    <dt>KVHX (legacy)</dt>
                    <dd>@_result.Adresseopslag?.KvHxInput.KvhxId</dd>
                </div>
                @if (!string.IsNullOrWhiteSpace(_result.Adresseopslag?.AdresseLocalId))
                {
                    <div>
                        <dt>Adresse LocalId (enhed)</dt>
                        <dd>@_result.Adresseopslag?.AdresseLocalId</dd>
                    </div>
                }
                <div>
                    <dt>Bygninger</dt>
                    <dd>@FormatBygninger(_result.Bygninger)</dd>
                </div>
                <div>
                    <dt>Enheder</dt>
                    <dd>@_result.Enheder.Count</dd>
                </div>
                <div>
                    <dt>Etager</dt>
                    <dd>@_result.Etager.Count</dd>
                </div>
                <div>
                    <dt>Opgange</dt>
                    <dd>@_result.Opgange.Count</dd>
                </div>
                <div>
                    <dt>Tekniske anlæg</dt>
                    <dd>@_result.TekniskeAnlaeg.Count</dd>
                </div>
                <div>
                    <dt>Ejendomsrelationer</dt>
                    <dd>@_result.Ejendomsrelationer.Count</dd>
                </div>
            </dl>
        </section>

        <section class="results">
            <h2>Service-resultater</h2>

            @if (_methodCalls is not null && _request.AutocompleteSelection is not null)
            {
                <div class="method-call--overview">
                    <h3>Anbefalet Azure Function-flow (autocomplete → KVHX)</h3>
                    <MethodCallHint Text="@_methodCalls.AutocompleteFlow" />
                </div>
            }

            @if (_methodCalls is not null)
            {
                <div class="method-call--overview">
                    <MethodCallHint Text="@_methodCalls.Overview" />
                </div>
            }

            <ResultPanel Title="Dar.Adresseopslag.Dar" Subtitle="DarAdresseopslagDto (native DAR)" MethodCall="@_methodCalls?.AdresseopslagDar" Data="_result.Adresseopslag?.Dar" Open="true" />
            <ResultPanel Title="Dar.Adresseopslag" Subtitle="AdresseopslagResult" MethodCall="@_methodCalls?.Adresseopslag" Data="_result.Adresseopslag" />
            <ResultPanel Title="Dar.Adresseopslag.KvHxInput" Subtitle="KvHxInputDto (DAWA legacy)" MethodCall="@_methodCalls?.KvHxInput" Data="_result.Adresseopslag?.KvHxInput" />
            <ResultPanel Title="Dar.Husnummer" Subtitle="HusnummerLookupResult" MethodCall="@_methodCalls?.Husnummer" Data="_result.Husnummer" />
            <ResultPanel Title="Bbr.Bygning" Subtitle="@($"{_result.Bygninger.Count} bygninger")" MethodCall="@_methodCalls?.Bygning" Data="_result.Bygninger" Open="true" />
            <ResultPanel Title="Bbr.Enhed" Subtitle="@($"{_result.Enheder.Count} enheder")" MethodCall="@_methodCalls?.Enhed" Data="_result.Enheder" />
            <ResultPanel Title="Bbr.Etage" Subtitle="@($"{_result.Etager.Count} etager")" MethodCall="@_methodCalls?.Etage" Data="_result.Etager" />
            <ResultPanel Title="Bbr.Opgang" Subtitle="@($"{_result.Opgange.Count} opgange")" MethodCall="@_methodCalls?.Opgang" Data="_result.Opgange" />
            <ResultPanel Title="Bbr.TekniskAnlaeg" Subtitle="@($"{_result.TekniskeAnlaeg.Count} anlæg")" MethodCall="@_methodCalls?.TekniskAnlaeg" Data="_result.TekniskeAnlaeg" />
            <ResultPanel Title="Bbr.Grund" Subtitle="GrundDto" MethodCall="@_methodCalls?.Grund" Data="_result.Grund" />
            <ResultPanel Title="Bbr.Grund.Jordstykker" Subtitle="@($"{_result.GrundJordstykker.Count} jordstykker")" MethodCall="@_methodCalls?.GrundJordstykker" Data="_result.GrundJordstykker" />
            <ResultPanel Title="Bbr.Ejendomsrelation (bygning)" Subtitle="@($"{_result.BygningEjendomsrelationer.Count} relationer")" MethodCall="@_methodCalls?.BygningEjendomsrelation" Data="_result.BygningEjendomsrelationer" />
            <ResultPanel Title="Bbr.Ejendomsrelation.Resolve" Subtitle="@($"{_result.Ejendomsrelationer.Count} relationer")" MethodCall="@_methodCalls?.Ejendomsrelation" Data="_result.Ejendomsrelationer" Open="true" />
        </section>
    }
</div>

@code {
    private readonly DarLookupRequest _request = new();
    private DarFullLookupResult? _result;
    private DarLookupMethodCalls.LookupMethodCalls? _methodCalls;
    private string? _errorMessage;
    private string? _configurationError;
    private bool _isLoading;

    protected override void OnInitialized()
    {
        _configurationError = Orchestrator.ConfigurationError;
    }

    private static string FormatBygninger(IReadOnlyList<BygningDto> bygninger) =>
        bygninger.Count == 0
            ? "-"
            : string.Join(", ", bygninger.Select(b => b.Bygningsnummer ?? b.IdLokalId ?? "?"));

    private async Task ApplyAutocompleteSelectionAsync(AutocompleteSelectionEventArgs selection)
    {
        var result = selection.Result;
        _request.AutocompleteSelection = result;
        _request.AutocompleteSearchText = selection.SearchText;

        if (result.IsCompleteAddress)
        {
            _request.StreetAndNumber = string.IsNullOrWhiteSpace(result.AddressLine2)
                ? result.AddressLine1
                : $"{result.AddressLine1}, {result.AddressLine2}";
            _request.PostalCode = result.PostalCode;
            _request.City = result.City;
        }
        else
        {
            _request.StreetAndNumber = result.AddressLine1;
            _request.PostalCode = result.PostalCode;
            _request.City = result.City;
        }

        await Task.CompletedTask;
    }

    private async Task RunLookupAsync()
    {
        _errorMessage = null;
        _result = null;
        _methodCalls = null;
        _isLoading = true;

        try
        {
            _result = await Orchestrator.LookupAllAsync(_request);
            _methodCalls = DarLookupMethodCalls.Build(_request, _result);
        }
        catch (DatafordelerApiException ex) when (ex.ResponseBody.Contains("DAF-AUTH-0005", StringComparison.Ordinal))
        {
            _errorMessage =
                "IP-adressen er ikke whitelisted i Datafordeler Administration (DAF-AUTH-0005). " +
                "Tilføj din udgående IP under https://administration.datafordeler.dk/";
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }
}
