@inherits LayoutComponentBase
@implements IDisposable
@using TheNerdCollective.MudComponents.DesignTokens
@using TheNerdCollective.MudComponents.ResponsiveTypography
@using TheNerdCollective.MudComponents.Shared
@inject IJSRuntime JS
@inject NerdDesignTokenOptions TokenOptions
@inject NerdDesignTokenCss TokenCss
@inject NerdDesignSystemOptions HubOptions
@inject NerdResponsiveTypographyOptions TypographyOptions
@inject NerdResponsiveTypographyCss TypographyCss
@inject NavigationManager Navigation

<NerdDesignTokenStyles />
<NerdDesignSystemScripts />
<MudThemeProvider Theme="@_theme" IsDarkMode="_isDarkMode" />
<NerdResponsiveTypographyStyles />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Transparent" Class="@RecipeClass("header")">
        <MudHidden Breakpoint="Breakpoint.SmAndUp">
            <MudIconButton Icon="@Icons.Material.Filled.Menu" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        </MudHidden>
        
        <div class="d-flex align-center ml-3">
            <img src="@HeaderLogoSrc" alt="The Nerd Collective" style="height: 32px; margin-right: 12px;" />
            <MudText Typo="Typo.h5">Components</MudText>
        </div>
        
        <MudSpacer />
        <MudIconButton Icon="@(DarkLightModeButtonIcon)" OnClick="@DarkModeToggle" />
    </MudAppBar>
    <MudDrawer id="nav-drawer" @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <NavMenu />
    </MudDrawer>
     <MudMainContent Style="@NerdDesignSystemUi.PageSurfaceStyle(LayoutSurfacePrefix)">
       <MudContainer MaxWidth="MaxWidth.Large" Class="my-6 pt-6">
        @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>


<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode = false;
    private MudTheme? _theme = null;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        Navigation.LocationChanged += OnLocationChanged;
        NerdBrandRuntime.RestoreDefaultBrand(
            TokenOptions,
            HubOptions,
            TypographyOptions,
            TokenCss,
            TypographyCss,
            _nerdTheme);
        ApplyTypography();
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e) => ApplyTypography();

    private void ApplyTypography()
    {
        _nerdTheme.UseResponsiveTypography(target => TypographyOptions.Typography.CopyTo(target));
        _theme = _nerdTheme;
        TypographyCss.Update(TypographyOptions.Typography);
    }

    public void Dispose() => Navigation.LocationChanged -= OnLocationChanged;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await JS.InvokeVoidAsync("mudQuillEditor.setDarkMode", _isDarkMode);
            }
            catch
            {
                // MudQuillEditor module not loaded on this page, that's OK
            }
        }
    }

    private void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    private async void DarkModeToggle()
    {
        _isDarkMode = !_isDarkMode;
        try
        {
            await JS.InvokeVoidAsync("mudQuillEditor.setDarkMode", _isDarkMode);
        }
        catch
        {
            // MudQuillEditor module not loaded on this page, that's OK
        }
        StateHasChanged();
    }

    public string DarkLightModeButtonIcon => _isDarkMode switch
    {
        true => Icons.Material.Rounded.AutoMode,
        false => Icons.Material.Outlined.DarkMode,
    };

    private string HeaderLogoSrc => _isDarkMode
        ? "images/logo-dark.svg"
        : "images/logo-light.svg";

    private string Ui(string semanticAlias) => NerdDesignSystemUi.TokenClass(TokenOptions.Prefix, semanticAlias);

    private string RecipeClass(string recipeName) => $"{LayoutSurfacePrefix}-recipe-{recipeName}";

    private string LayoutSurfacePrefix =>
        TokenOptions.DefaultBrandPackId ?? TokenOptions.Prefix;

    private readonly MudTheme _nerdTheme = new()
    {
        Typography = new Typography()
        {
            Default = new DefaultTypography
            {
                FontFamily = new[] { "Roboto", "Helvetica", "Arial", "sans-serif" },
                FontSize = "1rem",
                FontWeight = "400",
                LineHeight = "1.5",
                LetterSpacing = ".00938em"
            },
            H1 = new H1Typography
            {
                FontFamily = new[] { "Roboto", "Helvetica", "Arial", "sans-serif" },
                FontSize = "2.25rem",
                FontWeight = "500",
                LineHeight = "1.6",
                LetterSpacing = ".0075em"
            },
            H2 = new H2Typography
            {
                FontFamily = new[] { "Roboto", "Helvetica", "Arial", "sans-serif" },
                FontSize = "1.25rem",
                FontWeight = "300",
                LineHeight = "1.6",
                LetterSpacing = ".0075em"
            },
            H3 = new H3Typography
            {
                FontFamily = new[] { "Roboto", "Helvetica", "Arial", "sans-serif" },
                FontSize = "1.05rem",
                FontWeight = "200",
                LineHeight = "1.6",
                LetterSpacing = ".0075em"
            }
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#fff",
            Secondary = "#ff7a8a",
            Background = "#202020",
            DrawerBackground = "#202020"
        },
        PaletteLight = new PaletteLight
        {
            Black = NerdTncDesignTokenPresets.Ink,
            White = NerdTncDesignTokenPresets.Snow,
            Primary = NerdTncDesignTokenPresets.Navy,
            Secondary = NerdTncDesignTokenPresets.Coral,
            Tertiary = NerdTncDesignTokenPresets.Coral,
            AppbarBackground = NerdTncDesignTokenPresets.Snow,
            AppbarText = NerdTncDesignTokenPresets.Ink,
            Background = NerdTncDesignTokenPresets.Snow,
            BackgroundGray = "#F5F5F5",
            DrawerBackground = NerdTncDesignTokenPresets.Snow,
            DrawerText = "rgba(17, 24, 39, 0.87)",
            DrawerIcon = "rgba(17, 24, 39, 0.54)",
            TextPrimary = NerdTncDesignTokenPresets.Ink,
            TextSecondary = "#424242",
            TextDisabled = "rgba(17, 24, 39, 0.38)",
            ActionDefault = NerdTncDesignTokenPresets.Coral,
            ActionDisabled = "rgba(17, 24, 39, 0.26)",
            ActionDisabledBackground = "rgba(17, 24, 39, 0.12)",
            Surface = NerdTncDesignTokenPresets.Snow,
            Info = NerdTncDesignTokenPresets.Navy,
            Success = NerdTncDesignTokenPresets.Navy,
            Warning = NerdTncDesignTokenPresets.Coral,
            Error = NerdTncDesignTokenPresets.Coral,
            LinesDefault = "#E0E0E0",
            TableLines = "#E0E0E0",
            Divider = "#E0E0E0",
            OverlayLight = "rgba(18, 46, 67, 0.3)",
            GrayLight = "#E8E8E8",
            GrayLighter = "#F5F5F5"
        }
    };
}


