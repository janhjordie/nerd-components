@* Renders a single MudBlazor component preview for the PlayBook. *@
@switch (ComponentId)
{
    case "button":
        @if (IsPlayground)
        {
            <MudButton Class="@Tc" Variant="@PVariant()" Size="@PSize()" Disabled="@PBool("disabled")">@PText("text", "Button")</MudButton>
        }
        else
        {
            <MudStack Row="true" Spacing="1" Class="flex-wrap gap-1">
                <MudButton Class="@Tc" Variant="Variant.Filled" Size="Size.Small">Filled</MudButton>
                <MudButton Class="@Tc" Variant="Variant.Outlined" Size="Size.Small">Outlined</MudButton>
                <MudButton Class="@Tc" Variant="Variant.Text" Size="Size.Small">Text</MudButton>
            </MudStack>
        }
        break;
    case "icon-button":
        <MudIconButton Class="@Tc" Icon="@Icons.Material.Filled.Favorite" Variant="@PVariant(Variant.Filled)" Size="@PSize()" Disabled="@PBool("disabled")" />
        break;
    case "fab":
        <MudFab Class="@Tc" Icon="@Icons.Material.Filled.Add" Size="@PSize()" Disabled="@PBool("disabled")" />
        break;
    case "toggle-group":
        <MudToggleGroup T="string" @bind-Value="_toggleValue" Class="@Tc" Color="Color.Default" Variant="Variant.Outlined" Size="Size.Small">
            <MudToggleItem Value="@("a")" Class="@Tc">A</MudToggleItem>
            <MudToggleItem Value="@("b")" Class="@Tc">B</MudToggleItem>
        </MudToggleGroup>
        break;
    case "button-group":
        <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small">
            <MudButton Class="@Tc">One</MudButton>
            <MudButton Class="@Tc">Two</MudButton>
        </MudButtonGroup>
        break;
    case "text-field":
        <MudTextField T="string" @bind-Value="_textValue" Class="@Tc" Label="@PText("label", "Name")" Placeholder="@PText("placeholder", "Enter value")"
                      Variant="@PVariant(Variant.Outlined)" ReadOnly="@PBool("readOnly")" Disabled="@PBool("disabled")" Margin="Margin.Dense" />
        break;
    case "numeric-field":
        <MudNumericField T="int" @bind-Value="_numericValue" Class="@Tc" Label="@PText("label", "Amount")" Placeholder="@PText("placeholder", "0")"
                         Variant="@PVariant(Variant.Outlined)" ReadOnly="@PBool("readOnly")" Disabled="@PBool("disabled")" Margin="Margin.Dense" />
        break;
    case "select":
        <MudSelect T="string" @bind-Value="_selectValue" Class="@Tc" Label="@PText("label", "Option")" Variant="@PVariant(Variant.Outlined)"
                   Disabled="@PBool("disabled")" Margin="Margin.Dense">
            <MudSelectItem Value="@("alpha")">Alpha</MudSelectItem>
            <MudSelectItem Value="@("beta")">Beta</MudSelectItem>
        </MudSelect>
        break;
    case "autocomplete":
        <MudAutocomplete T="string" @bind-Value="_autocompleteValue" Class="@Tc" Label="@PText("label", "City")" Variant="@PVariant(Variant.Outlined)"
                         Disabled="@PBool("disabled")" ReadOnly="@PBool("readOnly")" SearchFunc="@SearchCities" Margin="Margin.Dense" />
        break;
    case "checkbox":
        <MudCheckBox @bind-Value="_checkValue" Class="@Tc" Label="@PText("label", "Accept")" Disabled="@PBool("disabled")" />
        break;
    case "radio":
        <MudRadioGroup T="string" @bind-Value="_radioValue">
            <MudRadio Class="@Tc" Value="@("a")" Disabled="@PBool("disabled")">A</MudRadio>
            <MudRadio Class="@Tc" Value="@("b")" Disabled="@PBool("disabled")">B</MudRadio>
        </MudRadioGroup>
        break;
    case "switch":
        <MudSwitch @bind-Value="_switchValue" Class="@Tc" Color="Color.Default" Label="@PText("label", "Enabled")" Disabled="@PBool("disabled")" />
        break;
    case "slider":
        <MudSlider @bind-Value="_sliderValue" Class="@Tc" Min="@PInt("min", 0)" Max="@PInt("max", 100)" Disabled="@PBool("disabled")" />
        break;
    case "rating":
        <MudRating @bind-SelectedValue="_ratingValue" Class="@Tc" MaxValue="@PInt("max", 5)" ReadOnly="@PBool("readOnly")" />
        break;
    case "date-picker":
        <MudDatePicker @bind-Date="_dateValue" Class="@Tc" Label="@PText("label", "Date")" Variant="@PVariant(Variant.Outlined)" Disabled="@PBool("disabled")" Margin="Margin.Dense" />
        break;
    case "time-picker":
        <MudTimePicker @bind-Time="_timeValue" Class="@Tc" Label="@PText("label", "Time")" Variant="@PVariant(Variant.Outlined)" Disabled="@PBool("disabled")" Margin="Margin.Dense" />
        break;
    case "date-range-picker":
        <MudDateRangePicker @bind-DateRange="_dateRangeValue" Class="@Tc" Label="@PText("label", "Range")" Variant="@PVariant(Variant.Outlined)" Disabled="@PBool("disabled")" Margin="Margin.Dense" />
        break;
    case "file-upload":
        <MudFileUpload T="IBrowserFile" Class="@Tc" Accept="image/*">
            <CustomContent>
                <MudButton Class="@Tc" Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.Upload">
                    Upload
                </MudButton>
            </CustomContent>
        </MudFileUpload>
        break;
    case "table":
        <MudTable Items="_tableItems" Class="@Tc" Dense="@PDense()" Hover="true" Bordered="true">
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Qty</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Name</MudTd>
                <MudTd>@context.Quantity</MudTd>
            </RowTemplate>
        </MudTable>
        break;
    case "simple-table":
        <MudSimpleTable Class="@Tc" Dense="@PDense()" Bordered="true">
            <tbody>
                <tr><td>Row</td><td>1</td></tr>
                <tr><td>Row</td><td>2</td></tr>
            </tbody>
        </MudSimpleTable>
        break;
    case "data-grid":
        <MudDataGrid T="PlayBookRow" Items="_tableItems" Class="@Tc" Dense="@PDense()" Bordered="true" Style="max-height:120px">
            <Columns>
                <PropertyColumn Property="x => x.Name" Title="Name" />
                <PropertyColumn Property="x => x.Quantity" Title="Qty" />
            </Columns>
        </MudDataGrid>
        break;
    case "chip":
        @if (IsPlayground)
        {
            <MudChip T="string" Class="@Tc" Variant="@PVariant()" Disabled="@PBool("disabled")">@PText("text", "Chip")</MudChip>
        }
        else
        {
            <MudStack Row="true" Spacing="1" Class="flex-wrap gap-1">
                <MudChip T="string" Class="@Tc" Variant="Variant.Filled">Filled</MudChip>
                <MudChip T="string" Class="@Tc" Variant="Variant.Outlined">Outlined</MudChip>
            </MudStack>
        }
        break;
    case "badge":
        <MudBadge Content="3" Overlap="true" Class="@Tc">
            <MudIcon Icon="@Icons.Material.Filled.Notifications" />
        </MudBadge>
        break;
    case "avatar":
        <MudStack Row="true" Spacing="1">
            <MudAvatar Class="@Tc">AB</MudAvatar>
            <MudAvatar Class="@Tc" Variant="Variant.Outlined">CD</MudAvatar>
        </MudStack>
        break;
    case "tooltip":
        <MudTooltip Text="Tooltip preview">
            <MudButton Class="@Tc" Variant="Variant.Outlined" Size="Size.Small">Hover me</MudButton>
        </MudTooltip>
        break;
    case "list":
        <MudList T="string" Dense="true" Class="@Tc">
            <MudListItem Icon="@Icons.Material.Filled.Home">Home</MudListItem>
            <MudListItem Icon="@Icons.Material.Filled.Settings">Settings</MudListItem>
        </MudList>
        break;
    case "tree-view":
        <MudTreeView T="string" Items="_treeItems" Dense="true" Class="@Tc" />
        break;
    case "timeline":
        <MudTimeline TimelinePosition="TimelinePosition.Start" Class="@Tc">
            <MudTimelineItem>
                <MudText Typo="Typo.body2">Step one</MudText>
            </MudTimelineItem>
            <MudTimelineItem>
                <MudText Typo="Typo.body2">Step two</MudText>
            </MudTimelineItem>
        </MudTimeline>
        break;
    case "typography":
        <MudText Typo="@PTypo()" Class="@Tc">@PText("text", "Typography preview")</MudText>
        break;
    case "icon":
        <MudStack Row="true" Spacing="1">
            <MudIcon Class="@Tc" Icon="@Icons.Material.Filled.Star" />
            <MudIcon Class="@Tc" Icon="@Icons.Material.Filled.Favorite" />
        </MudStack>
        break;
    case "image":
        <MudImage Class="@Tc" Src="@NerdPlayBookPreviewAssets.PreviewImageSrc" Alt="Preview" Width="120" Height="48" ObjectFit="ObjectFit.Cover" />
        break;
    case "markdown":
        <MudText Typo="Typo.body2" Class="@Tc"><b>Bold</b> and <i>italic</i> text preview.</MudText>
        break;
    case "alert":
        <MudAlert Class="@Tc" Severity="@PSeverity()" Variant="@PVariant(Variant.Filled)" Dense="@PDense()">@PText("text", "Alert preview")</MudAlert>
        break;
    case "progress-circular":
        <MudProgressCircular Class="@Tc" Indeterminate="@PBool("indeterminate", true)" Value="@PInt("value", 60)" Size="Size.Small" />
        break;
    case "progress-linear":
        <MudProgressLinear Class="@Tc" Indeterminate="@PBool("indeterminate")" Value="@PInt("value", 60)" />
        break;
    case "skeleton":
        <MudSkeleton Class="@Tc" Width="100%" Height="40px" Animation="Animation.Wave" />
        break;
    case "paper":
        <MudPaper Class="@($"{Tc} pa-3")" Elevation="1">Paper surface</MudPaper>
        break;
    case "card":
        <MudCard Class="@Tc" Elevation="1">
            <MudCardContent>
                <MudText Typo="Typo.body2">Card content</MudText>
            </MudCardContent>
        </MudCard>
        break;
    case "expansion-panel":
        <MudExpansionPanels Class="@Tc" Elevation="0">
            <MudExpansionPanel Text="Panel" Dense="true">
                <MudText Typo="Typo.body2">Expanded content</MudText>
            </MudExpansionPanel>
        </MudExpansionPanels>
        break;
    case "drawer":
        <div style="position:relative;height:100px;overflow:hidden">
            <MudDrawer Open="true" Variant="DrawerVariant.Persistent" Class="@Tc" ClipMode="DrawerClipMode.Never" Style="position:absolute;width:120px">
                <MudText Typo="Typo.caption" Class="pa-2">Drawer</MudText>
            </MudDrawer>
        </div>
        break;
    case "popover":
        <MudButton Class="@Tc" Variant="Variant.Outlined" Size="Size.Small" OnClick="@(() => _popoverOpen = !_popoverOpen)">
            Popover
        </MudButton>
        <MudPopover Open="_popoverOpen" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
            <MudPaper Class="pa-3">Popover content</MudPaper>
        </MudPopover>
        break;
    case "app-bar":
        <div style="position:relative">
            <MudAppBar Class="@Tc" Dense="true" Fixed="false" Elevation="0">
                <MudIconButton Icon="@Icons.Material.Filled.Menu" Size="Size.Small" />
                <MudText Typo="Typo.subtitle2">App bar</MudText>
            </MudAppBar>
        </div>
        break;
    case "nav-menu":
        <MudNavMenu Dense="true" Class="@Tc">
            <MudNavLink Icon="@Icons.Material.Filled.Home" Href="#">Home</MudNavLink>
            <MudNavLink Icon="@Icons.Material.Filled.Settings" Href="#">Settings</MudNavLink>
        </MudNavMenu>
        break;
    case "tabs":
        <MudTabs Class="@Tc" Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-2">
            <MudTabPanel Text="Tab 1"><MudText Typo="Typo.body2">One</MudText></MudTabPanel>
            <MudTabPanel Text="Tab 2"><MudText Typo="Typo.body2">Two</MudText></MudTabPanel>
        </MudTabs>
        break;
    case "breadcrumbs":
        <MudBreadcrumbs Class="@Tc" Items="_breadcrumbs" />
        break;
    case "menu":
        <MudMenu Label="Menu" Dense="true" Class="@Tc">
            <MudMenuItem>Item 1</MudMenuItem>
            <MudMenuItem>Item 2</MudMenuItem>
        </MudMenu>
        break;
    case "pagination":
        <MudPagination Class="@Tc" Count="5" Selected="_page" SelectedChanged="p => _page = p" />
        break;
    case "stepper":
        <MudStepper Class="@Tc" @bind-ActiveIndex="_stepIndex" Style="max-width:280px">
            <MudStep Title="Start" />
            <MudStep Title="Done" />
        </MudStepper>
        break;
    case "grid":
        <MudGrid Class="@Tc" Spacing="1">
            <MudItem xs="6"><MudPaper Class="pa-2" Outlined="true">A</MudPaper></MudItem>
            <MudItem xs="6"><MudPaper Class="pa-2" Outlined="true">B</MudPaper></MudItem>
        </MudGrid>
        break;
    case "container":
        <MudContainer MaxWidth="MaxWidth.Small" Class="@($"{Tc} pa-0")">
            <MudPaper Class="pa-2" Outlined="true">Container</MudPaper>
        </MudContainer>
        break;
    case "divider":
        <MudStack Spacing="1" Class="@Tc">
            <MudText Typo="Typo.caption">Above</MudText>
            <MudDivider />
            <MudText Typo="Typo.caption">Below</MudText>
        </MudStack>
        break;
    case "stack":
        <MudStack Class="@Tc" Spacing="1">
            <MudPaper Class="pa-1" Outlined="true">Stack 1</MudPaper>
            <MudPaper Class="pa-1" Outlined="true">Stack 2</MudPaper>
        </MudStack>
        break;
    case "spacer":
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="@Tc" Style="width:100%">
            <MudText Typo="Typo.caption">Left</MudText>
            <MudSpacer />
            <MudText Typo="Typo.caption">Right</MudText>
        </MudStack>
        break;
    default:
        <MudText Typo="Typo.caption">Preview not available.</MudText>
        break;
}

@code {
    [Parameter, EditorRequired]
    public string ComponentId { get; set; } = string.Empty;

    private string _toggleValue = "a";
    private string _textValue = "Sample";
    private int _numericValue = 42;
    private string _selectValue = "alpha";
    private string? _autocompleteValue = "Copenhagen";
    private bool _checkValue = true;
    private string _radioValue = "a";
    private bool _switchValue = true;
    private int _sliderValue = 40;
    private int _ratingValue = 3;
    private DateTime? _dateValue = DateTime.Today;
    private TimeSpan? _timeValue = new(9, 30, 0);
    private DateRange _dateRangeValue = new(DateTime.Today, DateTime.Today.AddDays(7));
    private bool _popoverOpen;
    private int _page = 1;
    private int _stepIndex;

    private readonly List<PlayBookRow> _tableItems =
    [
        new("Alpha", 1),
        new("Beta", 2)
    ];

    private readonly List<TreeItemData<string>> _treeItems =
    [
        new TreeItemData<string>
        {
            Text = "Parent",
            Children = new List<TreeItemData<string>> { new() { Text = "Child" } }
        }
    ];

    private readonly List<BreadcrumbItem> _breadcrumbs =
    [
        new BreadcrumbItem("Home", href: "#"),
        new BreadcrumbItem("PlayBook", href: null, disabled: true)
    ];

    private Task<IEnumerable<string>> SearchCities(string value, CancellationToken token)
    {
        string[] cities = ["Copenhagen", "Aarhus", "Odense"];
        IEnumerable<string> results = cities.Where(city =>
            string.IsNullOrWhiteSpace(value) || city.Contains(value, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(results);
    }

    private sealed record PlayBookRow(string Name, int Quantity);
}
