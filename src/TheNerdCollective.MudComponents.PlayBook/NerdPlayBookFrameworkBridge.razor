@using TheNerdCollective.MudComponents.DesignTokens
@using TheNerdCollective.MudComponents.Shared
@using Radzen.Blazor

<MudPaper Outlined="true" Class="pa-4" data-testid="playbook-framework-bridge-panel" @key="@TokenOptions.Prefix">
    <MudText Typo="Typo.h6">Framework bridge</MudText>
    <MudText Typo="Typo.body2" Class="@Ui(NerdDesignSystemUi.MutedContent)">
        Same token pack drives Mud, Radzen, Fluent, Bootstrap 5 and Blazorise via <code>--nerd-intent-*</code>.
    </MudText>

    <MudGrid Spacing="3" Class="mt-3">
        <MudItem xs="12" md="4">
            <MudText Typo="Typo.subtitle2">MudBlazor (live)</MudText>
            <MudStack Spacing="2" Class="@($"{BrandRootClass} mt-2 pa-3")" Style="border: 1px solid var(--mud-palette-lines-default); border-radius: 8px;">
                <MudButton Variant="Variant.Filled" Color="Color.Primary">Color.Primary</MudButton>
                <MudButton Variant="Variant.Filled" Class="@Ui(NerdDesignSystemUi.PrimaryAction)">primary-action</MudButton>
            </MudStack>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudText Typo="Typo.subtitle2">Fluent token map (CSS)</MudText>
            <MudSimpleTable Dense="true" Hover="true" Bordered="true" Class="mt-2">
                <thead>
                    <tr>
                        <th>Fluent token</th>
                        <th>Nerd intent</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in FluentRows)
                    {
                        <tr data-testid="@($"fluent-map-{row.TestId}")">
                            <td><code>@row.FluentToken</code></td>
                            <td><code>@row.IntentReference</code></td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudText Typo="Typo.subtitle2">Radzen (live)</MudText>
            <div class="@($"{RadzenRootClass} pa-3 mt-2")" data-testid="radzen-preview-panel">
                <RadzenButton ButtonStyle="Radzen.ButtonStyle.Primary"
                              Text="RadzenButton Primary"
                              data-testid="radzen-live-primary-button" />
                <RadzenButton ButtonStyle="Radzen.ButtonStyle.Secondary"
                              Text="Secondary"
                              Class="ms-2"
                              data-testid="radzen-live-secondary-button" />
                <RadzenCard Class="mt-3">
                    <MudText Typo="Typo.body2" Style="color: var(--rz-text-secondary-color);">
                        Live Radzen components using <code>--rz-*</code> from the active pack.
                    </MudText>
                </RadzenCard>
            </div>
            <MudSimpleTable Dense="true" Hover="true" Bordered="true" Class="mt-2">
                <thead>
                    <tr>
                        <th>Radzen variable</th>
                        <th>Nerd intent</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in RadzenRows)
                    {
                        <tr data-testid="@($"radzen-map-{row.TestId}")">
                            <td><code>@row.RadzenToken</code></td>
                            <td><code>@row.IntentReference</code></td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudText Typo="Typo.subtitle2">Blazorise (Bootstrap bridge)</MudText>
            <div class="@($"{BlazoriseRootClass} pa-3 mt-2")" data-testid="blazorise-preview-panel"
                 style="border: 1px solid var(--bs-border-color); border-radius: 8px; background: var(--bs-body-bg); color: var(--bs-body-color);">
                <button type="button" class="btn btn-primary me-2" data-testid="blazorise-primary-button">Blazorise primary</button>
                <MudText Typo="Typo.caption" Class="mt-2">
                    Apply <code>@NerdBlazorisePaletteManifest.BrandRootClass(TokenOptions.Prefix)</code> with Bootstrap root — see
                    <code>reference/blazorise/1.7.3/</code>.
                </MudText>
            </div>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudText Typo="Typo.subtitle2">Bootstrap 5 (CSS map)</MudText>
            <div class="@($"{BootstrapRootClass} pa-3 mt-2")" data-testid="bootstrap-preview-panel"
                        style="border: 1px solid var(--bs-border-color); border-radius: 8px; background: var(--bs-body-bg); color: var(--bs-body-color);">
                <button type="button" class="btn btn-primary me-2" data-testid="bootstrap-primary-button">btn-primary</button>
                <button type="button" class="btn btn-outline-secondary" data-testid="bootstrap-secondary-button">btn-secondary</button>
                <div class="mt-2">
                    <a href="#" data-testid="bootstrap-link" style="color: var(--bs-link-color);">Link uses --bs-link-color</a>
                </div>
            </div>
            <MudSimpleTable Dense="true" Hover="true" Bordered="true" Class="mt-2">
                <thead>
                    <tr>
                        <th>Bootstrap variable</th>
                        <th>Nerd intent</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in BootstrapRows)
                    {
                        <tr data-testid="@($"bootstrap-map-{row.TestId}")">
                            <td><code>@row.BootstrapToken</code></td>
                            <td><code>@row.IntentReference</code></td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        </MudItem>
    </MudGrid>

    <MudText Typo="Typo.subtitle2" Class="mt-4">Spacing scale</MudText>
    @if (TokenOptions.Spacing.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-2">
            No spacing tokens in the active pack. Add <code>spacing</code> in the token pack or call <code>NerdSpacingScaleTools.ApplyDefaultScale</code>.
        </MudAlert>
    }
    else
    {
        <MudStack Row="true" Spacing="2" Class="flex-wrap mt-2">
            @foreach (var pair in TokenOptions.Spacing.OrderBy(entry => entry.Key, StringComparer.Ordinal))
            {
                <MudPaper Outlined="true" Class="@($"{SpacingClass(pair.Key)} pa-2")" data-testid="@($"spacing-{pair.Key}")">
                    <MudText Typo="Typo.caption"><code>@pair.Key</code> · @pair.Value</MudText>
                </MudPaper>
            }
        </MudStack>
    }
</MudPaper>

@code {
    [Parameter, EditorRequired]
    public NerdDesignTokenOptions TokenOptions { get; set; } = default!;

    private string BrandRootClass => NerdBrandRootClasses.Combine(TokenOptions.Prefix);

    private string RadzenRootClass => $"{NerdIntentCssManifest.BrandRootClass(TokenOptions.Prefix)} {NerdRadzenPaletteManifest.BrandRootClass(TokenOptions.Prefix)}";

    private string Ui(string semanticAlias) =>
        NerdDesignSystemUi.TokenClass(TokenOptions.Prefix, semanticAlias);

    private string SpacingClass(string name) => $"{TokenOptions.Prefix}-space-{name}";

    private IReadOnlyList<FluentMapRow> FluentRows { get; } =
    [
        new("--colorBrandBackground", "primary-action.surface", "brand-background"),
        new("--colorBrandForeground1", "on-primary-action.content", "brand-foreground"),
        new("--colorNeutralBackground1", "page-surface.surface", "neutral-background"),
        new("--colorNeutralForeground1", "page-surface.content", "neutral-foreground"),
        new("--colorNeutralForeground2", "muted-content.content", "neutral-foreground-secondary"),
        new("--colorNeutralStroke1", "input-border.border", "neutral-stroke"),
        new("--colorStrokeFocus1", "focus-ring.interactive", "focus-stroke")
    ];

    private sealed record FluentMapRow(string FluentToken, string IntentReference, string TestId);

    private IReadOnlyList<RadzenMapRow> RadzenRows { get; } =
    [
        new("--rz-primary", "primary-action.surface", "primary"),
        new("--rz-secondary", "secondary-action.surface", "secondary"),
        new("--rz-body-background-color", "page-surface.surface", "body-background"),
        new("--rz-text-color", "page-surface.content", "text-color"),
        new("--rz-text-secondary-color", "muted-content.content", "text-secondary"),
        new("--rz-danger", "danger.surface", "danger")
    ];

    private string BootstrapRootClass =>
        $"{NerdIntentCssManifest.BrandRootClass(TokenOptions.Prefix)} {NerdBootstrapPaletteManifest.BrandRootClass(TokenOptions.Prefix)}";

    private string BlazoriseRootClass =>
        $"{BootstrapRootClass} {NerdBlazorisePaletteManifest.BrandRootClass(TokenOptions.Prefix)}";

    private IReadOnlyList<BootstrapMapRow> BootstrapRows { get; } =
    [
        new("--bs-primary", "primary-action.surface", "primary"),
        new("--bs-secondary", "secondary-action.surface", "secondary"),
        new("--bs-body-bg", "page-surface.surface", "body-bg"),
        new("--bs-body-color", "page-surface.content", "body-color"),
        new("--bs-border-color", "input-border.border", "border"),
        new("--bs-link-color", "primary-action.interactive", "link")
    ];

    private sealed record BootstrapMapRow(string BootstrapToken, string IntentReference, string TestId);

    private sealed record RadzenMapRow(string RadzenToken, string IntentReference, string TestId);
}
