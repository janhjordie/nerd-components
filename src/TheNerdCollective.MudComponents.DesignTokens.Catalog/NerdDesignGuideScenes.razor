@using TheNerdCollective.MudComponents.DesignTokens
@using TheNerdCollective.MudComponents.Shared

@if (TokenOptions.Recipes.Count > 0)
{
    <MudStack Spacing="3">
        <MudText Typo="Typo.h5">Layout scenes</MudText>
        @if (DarkHeroRecipeName is not null)
        {
            <MudPaper Outlined="true"
                      Class="@($"{RecipeClass(DarkHeroRecipeName)} pa-8")"
                      data-testid="design-guide-hero-dark"
                      Style="@(UsesHeroOverlay(DarkHeroRecipeName) ? "position:relative; overflow:hidden; min-height: 280px;" : "min-height: 280px;")">
                @if (UsesHeroOverlay(DarkHeroRecipeName))
                {
                    <div class="@($"{TokenOptions.Prefix}-opacity-hero-overlay")"
                         style="position:absolute; inset:0; pointer-events:none;"
                         aria-hidden="true"></div>
                }
                <div style="@(UsesHeroOverlay(DarkHeroRecipeName) ? "position:relative;" : null)">
                    <MudText Typo="Typo.h3">@SceneHeadline</MudText>
                    <MudText Typo="Typo.body1" Class="mt-2">@SceneSubline</MudText>
                    <MudButton Class="@($"{Ui(NerdDesignSystemUi.PrimaryAction)} mt-4")"
                               Variant="Variant.Filled"
                               data-testid="design-guide-hero-dark-cta">
                        @SceneCta
                    </MudButton>
                    <MudText Typo="Typo.caption" Class="@($"{Ui(NerdDesignSystemUi.MutedContent)} mt-4")">
                        Recipe scope <code>:root .@RecipeClass(DarkHeroRecipeName)</code>
                    </MudText>
                </div>
            </MudPaper>
        }

        <MudPaper Outlined="true" Class="@($"{SceneClass} overflow-hidden")" data-testid="design-guide-layout-scene">
            @if (ShowSceneHero && TryGetRecipe("hero-photo", out _))
            {
                <MudPaper Class="@($"{RecipeClass("hero-photo")} pa-6")" Square="true" Elevation="0">
                    <MudText Typo="Typo.h4">@SceneHeadline</MudText>
                    <MudText Typo="Typo.body1" Class="mt-2">@SceneSubline</MudText>
                    <MudButton Class="@($"{Ui(NerdDesignSystemUi.PrimaryAction)} mt-4")" Variant="Variant.Filled">
                        @SceneCta
                    </MudButton>
                </MudPaper>
            }
            else if (ShowSceneHero && TryGetRecipe("hero", out _))
            {
                <MudPaper Class="@($"{RecipeClass("hero")} pa-6")" Square="true" Elevation="0">
                    <MudText Typo="Typo.h4">@SceneHeadline</MudText>
                    <MudText Typo="Typo.body1" Class="mt-2">@SceneSubline</MudText>
                    <MudButton Class="@($"{Ui(NerdDesignSystemUi.PrimaryAction)} mt-4")" Variant="Variant.Filled">
                        @SceneCta
                    </MudButton>
                </MudPaper>
            }

            <MudGrid Class="ma-0">
                @if (TryGetRecipe(NerdDesignSystemUi.SidebarRecipe, out _))
                {
                    <MudItem xs="12" md="3" Class="pa-0">
                        <MudPaper Class="@($"{RecipeClass(NerdDesignSystemUi.SidebarRecipe)} pa-2")" Square="true" Elevation="0" Style="min-height: 200px;">
                            <MudText Typo="Typo.overline" Class="pa-2">Navigation</MudText>
                            <MudNavMenu>
                                <MudNavLink Icon="@Icons.Material.Filled.Home">Home</MudNavLink>
                                <MudNavLink Icon="@Icons.Material.Filled.Campaign" active="true">Campaign</MudNavLink>
                                <MudNavLink Icon="@Icons.Material.Filled.Info">About</MudNavLink>
                            </MudNavMenu>
                        </MudPaper>
                    </MudItem>
                }
                <MudItem xs="12" md="@(TryGetRecipe(NerdDesignSystemUi.SidebarRecipe, out _) ? 9 : 12)" Class="pa-6">
                    <MudText Typo="Typo.h5">Main content</MudText>
                    <MudText Typo="Typo.body2" Class="@Ui(NerdDesignSystemUi.MutedContent)">
                        Page surface · <code>@Ui(NerdDesignSystemUi.PageSurface)</code>
                    </MudText>
                </MudItem>
            </MudGrid>

            @if (TryGetRecipe("footer", out _) || TryGetRecipe("footer-minimal", out _))
            {
                var footerName = TokenOptions.Recipes.ContainsKey("footer-minimal") ? "footer-minimal" : "footer";
                <MudPaper Class="@($"{RecipeClass(footerName)} pa-3")" Square="true" Elevation="0">
                    <MudText Typo="Typo.caption" Align="Align.Center">Footer · <code>@RecipeClass(footerName)</code></MudText>
                </MudPaper>
            }
        </MudPaper>
    </MudStack>
}

@code {
    [Parameter, EditorRequired]
    public NerdDesignTokenOptions TokenOptions { get; set; } = default!;

    private bool IsDnf =>
        string.Equals(TokenOptions.Prefix, "dnf", StringComparison.OrdinalIgnoreCase);

    private string? DarkHeroRecipeName =>
        TryGetRecipe("hero-photo", out _) ? "hero-photo" :
        TryGetRecipe("hero-organic", out _) ? "hero-organic" :
        TryGetRecipe("hero", out _) ? "hero" :
        null;

    private bool ShowSceneHero => DarkHeroRecipeName is null;

    private string SceneClass => Ui(NerdDesignSystemUi.PageSurface);

    private string SceneHeadline =>
        IsDnf ? "Stop bundtrawl i beskyttet hav!" : "Protect nature together";

    private string SceneSubline =>
        IsDnf ? "DNF design manual reference scene." : "TNC shell scene from pack recipes.";

    private string SceneCta =>
        IsDnf ? "Skriv under" : "Get involved";

    private string Ui(string semanticAlias) =>
        NerdDesignSystemUi.TokenClass(TokenOptions.Prefix, semanticAlias);

    private string RecipeClass(string recipeName) =>
        NerdDesignSystemUi.RecipeClass(TokenOptions.Prefix, recipeName);

    private bool TryGetRecipe(string name, out NerdDesignTokenRecipe recipe) =>
        TokenOptions.Recipes.TryGetValue(name, out recipe!);

    private bool UsesHeroOverlay(string recipeName) =>
        (string.Equals(recipeName, "hero-photo", StringComparison.OrdinalIgnoreCase) ||
         string.Equals(recipeName, "hero-organic", StringComparison.OrdinalIgnoreCase)) &&
        TokenOptions.Opacities.ContainsKey("hero-overlay");
}
