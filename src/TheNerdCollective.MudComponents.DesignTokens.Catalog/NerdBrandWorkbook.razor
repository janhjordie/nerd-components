@if (!IsAvailable)
{
    <MudContainer MaxWidth="MaxWidth.Medium" Class="my-8">
        <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">
            Brand workbook is disabled or only available in Development.
        </MudAlert>
    </MudContainer>
}
else
{
    @if (!Entitlements.CanUseWorkbook())
    {
        <MudContainer MaxWidth="MaxWidth.Medium" Class="my-8">
            <NerdCatalogUpgradePromptSection
                Show="true"
                Title="Brand workbook is not enabled"
                Description="Configure catalog entitlements in your host application to use the workbook workflow." />
            <MudButton Href="@HubOptions.HubRoute" Variant="Variant.Text" Class="mt-3">Back to design system</MudButton>
        </MudContainer>
    }
    else
    {
    <HeadContent>
        <link rel="stylesheet" href="_content/Radzen.Blazor/css/material-base.css" />
    </HeadContent>
    <NerdDesignSystemScripts />
    <NerdCatalogThemeProvider IsDarkMode="false">
        <NerdDesignTokenStyles />
        <NerdCatalogPage MaxWidth="MaxWidth.Large">
            <MudStack Spacing="3">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="flex-wrap gap-3">
                    <div>
                        <MudText Typo="Typo.h4">Brand workbook</MudText>
                        <MudText Typo="Typo.body2" Class="@Ui(NerdDesignSystemUi.MutedContent)">
                            JSON-first onboarding: import, edit palette/aliases/recipes/pairings, export for your client.
                        </MudText>
                    </div>
                    <MudButton Href="@HubOptions.HubRoute" Variant="Variant.Text" Class="@Ui(NerdDesignSystemUi.MutedContent)">Design system</MudButton>
                </MudStack>

                <MudStepper @bind-ActiveIndex="_activeStep" Class="mb-2">
                    <MudStep Title="Import" />
                    <MudStep Title="Palette" />
                    <MudStep Title="Aliases" />
                    <MudStep Title="Intents" />
                    <MudStep Title="Recipes" />
                    <MudStep Title="Pairings" />
                    <MudStep Title="Theme sets" />
                    <MudStep Title="Spacing" />
                    <MudStep Title="Transforms" />
                    <MudStep Title="Export" />
                </MudStepper>

                @switch (_activeStep)
                {
                    case 0:
                        <NerdBrandPackImporter Options="Options" OnImported="ApplyImportedPackAsync" />
                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                            Reference packs live in <code>reference/brands/*.token-pack.json</code>.
                        </MudAlert>
                        break;
                    case 1:
                        <MudPaper Outlined="true" Class="pa-4">
                            <MudText Typo="Typo.h6">Palette (@Options.Colors.Count tokens)</MudText>
                            <MudStack Row="true" Spacing="2" Class="flex-wrap mt-2 mb-3">
                                <MudTextField @bind-Value="_newTokenName" Label="New token" Immediate="true" />
                                <MudTextField @bind-Value="_newTokenValue" Label="Hex value" Immediate="true" />
                                <MudButton Variant="Variant.Filled" Class="@Ui(NerdDesignSystemUi.BrandChrome)" OnClick="AddColorAsync">Add color</MudButton>
                            </MudStack>
                            <MudSimpleTable Dense="true" Bordered="true" Hover="true">
                                <thead><tr><th>Token</th><th>Value</th><th>Locked</th><th></th></tr></thead>
                                <tbody>
                                    @foreach (var pair in Options.Colors.OrderBy(p => p.Key, StringComparer.Ordinal))
                                    {
                                        var tokenName = pair.Key;
                                        var locked = Options.IsTokenLocked(tokenName);
                                        <tr>
                                            <td><code>@tokenName</code></td>
                                            <td>
                                                <MudTextField Value="@pair.Value.Value"
                                                              ValueChanged="@((string value) => UpdateColorAsync(tokenName, value))"
                                                              Immediate="true"
                                                              Disabled="@locked" />
                                            </td>
                                            <td>@(locked ? "yes" : "—")</td>
                                            <td>
                                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                               Disabled="@locked"
                                                               OnClick="@(() => RemoveColorAsync(tokenName))" />
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        </MudPaper>
                        break;
                    case 2:
                        <MudPaper Outlined="true" Class="pa-4">
                            <MudText Typo="Typo.h6">Semantic aliases</MudText>
                            <MudStack Row="true" Spacing="2" Class="flex-wrap mt-2 mb-3">
                                <MudTextField @bind-Value="_newAliasName" Label="Alias" Immediate="true" />
                                <MudSelect T="string" @bind-Value="_newAliasTarget" Label="Target token">
                                    @foreach (var tokenName in TokenNames)
                                    {
                                        <MudSelectItem Value="@tokenName">@tokenName</MudSelectItem>
                                    }
                                </MudSelect>
                                <MudButton Variant="Variant.Filled" Class="@Ui(NerdDesignSystemUi.BrandChrome)" OnClick="AddAliasAsync">Add alias</MudButton>
                            </MudStack>
                            <MudSimpleTable Dense="true" Bordered="true" Hover="true">
                                <thead><tr><th>Alias</th><th>Token</th><th></th></tr></thead>
                                <tbody>
                                    @foreach (var pair in Options.Aliases.OrderBy(p => p.Key, StringComparer.Ordinal))
                                    {
                                        var aliasName = pair.Key;
                                        <tr>
                                            <td><code>@aliasName</code></td>
                                            <td>
                                                <MudSelect T="string"
                                                           Value="@pair.Value"
                                                           ValueChanged="@((string value) => UpdateAliasAsync(aliasName, value))"
                                                           Dense="true">
                                                    @foreach (var tokenName in TokenNames)
                                                    {
                                                        <MudSelectItem Value="@tokenName">@tokenName</MudSelectItem>
                                                    }
                                                </MudSelect>
                                            </td>
                                            <td>
                                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                               OnClick="@(() => RemoveAliasAsync(aliasName))" />
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        </MudPaper>
                        break;
                    case 3:
                        <MudPaper Outlined="true" Class="pa-4" data-testid="workbook-intents-panel">
                            <MudText Typo="Typo.h6">Component intents</MudText>
                            <MudText Typo="Typo.body2" Class="@Ui(NerdDesignSystemUi.MutedContent)">
                                Map semantic intents to palette tokens — use these in markup instead of raw color names.
                            </MudText>
                            <MudGrid Spacing="2" Class="mt-3 mb-3">
                                <MudItem xs="12" md="4">
                                    <MudSelect T="string" @bind-Value="_selectedIntent" Label="Intent">
                                        @foreach (var intent in NerdIntentCatalogTools.StandardIntents)
                                        {
                                            <MudSelectItem Value="@intent.Name">@intent.Name</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudSelect T="string" @bind-Value="_intentTarget" Label="Maps to token">
                                        @foreach (var tokenName in TokenNames)
                                        {
                                            <MudSelectItem Value="@tokenName">@tokenName</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" md="4" Class="d-flex align-end">
                                    <MudButton Variant="Variant.Filled" Class="@Ui(NerdDesignSystemUi.BrandChrome)" OnClick="ApplyIntentAliasAsync">Apply intent</MudButton>
                                </MudItem>
                            </MudGrid>
                            @if (SelectedIntentEntry is not null)
                            {
                                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mb-3">
                                    <strong>@SelectedIntentEntry.Name</strong> — @SelectedIntentEntry.Summary
                                    <br />Usage: @SelectedIntentEntry.UsageHint
                                    <br />Class: <code>@IntentClass</code>
                                </MudAlert>
                            }
                            <MudGrid Spacing="2" Class="mt-2">
                                <MudItem xs="12" md="6">
                                    <MudText Typo="Typo.subtitle2">MudBlazor</MudText>
                                    <MudStack Row="true" Spacing="2" Class="@($"{BrandRootClass} flex-wrap mt-2 pa-3")"
                                              Style="border: 1px solid var(--mud-palette-lines-default); border-radius: 8px;"
                                              data-testid="workbook-intent-mud-preview">
                                        <MudButton Variant="Variant.Filled" Class="@IntentClass">Primary button</MudButton>
                                        <MudButton Variant="Variant.Outlined" Class="@Ui(NerdDesignSystemUi.SecondaryAction)">Secondary</MudButton>
                                        <MudTextField T="string" Class="@Ui(NerdDesignSystemUi.InputSurface)" Label="Input preview" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                    </MudStack>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudText Typo="Typo.subtitle2">Radzen (live)</MudText>
                                    <MudStack Spacing="2" Class="@($"{RadzenRootClass} mt-2 pa-3")"
                                              Style="border: 1px solid var(--mud-palette-lines-default); border-radius: 8px;"
                                              data-testid="workbook-intent-radzen-preview">
                                        <RadzenButton Text="Primary" ButtonStyle="Radzen.ButtonStyle.Primary"
                                                      data-testid="workbook-radzen-primary-button" />
                                        <RadzenButton Text="Secondary" ButtonStyle="Radzen.ButtonStyle.Secondary"
                                                      data-testid="workbook-radzen-secondary-button" />
                                    </MudStack>
                                </MudItem>
                            </MudGrid>
                            <MudSimpleTable Dense="true" Bordered="true" Hover="true">
                                <thead><tr><th>Intent</th><th>Token</th></tr></thead>
                                <tbody>
                                    @foreach (var intent in NerdIntentCatalogTools.StandardIntents)
                                    {
                                        var target = NerdIntentCatalogTools.ResolveAliasTarget(Options, intent.Name) ?? "—";
                                        <tr>
                                            <td><code>@intent.Name</code></td>
                                            <td><code>@target</code></td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        </MudPaper>
                        break;
                    case 4:
                        <MudPaper Outlined="true" Class="pa-4">
                            <MudText Typo="Typo.h6">Recipes</MudText>
                            <MudGrid Spacing="2" Class="mt-2 mb-3">
                                <MudItem xs="12" md="2"><MudTextField @bind-Value="_newRecipeName" Label="Name" Immediate="true" /></MudItem>
                                <MudItem xs="12" md="2">
                                    <MudSelect T="string" @bind-Value="_newRecipeSurface" Label="Surface">
                                        @foreach (var tokenName in TokenNames) { <MudSelectItem Value="@tokenName">@tokenName</MudSelectItem> }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" md="2">
                                    <MudSelect T="string" @bind-Value="_newRecipeContent" Label="Content">
                                        @foreach (var tokenName in TokenNames) { <MudSelectItem Value="@tokenName">@tokenName</MudSelectItem> }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" md="2">
                                    <MudSelect T="string" @bind-Value="_newRecipeAction" Label="Action" Clearable="true">
                                        @foreach (var tokenName in TokenNames) { <MudSelectItem Value="@tokenName">@tokenName</MudSelectItem> }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" md="2"><MudTextField @bind-Value="_newRecipeLabel" Label="Label" Immediate="true" /></MudItem>
                                <MudItem xs="12" md="2"><MudTextField @bind-Value="_newRecipeUsage" Label="Usage" Immediate="true" /></MudItem>
                                <MudItem xs="12">
                                    <MudButton Variant="Variant.Filled" Class="@Ui(NerdDesignSystemUi.BrandChrome)" OnClick="AddRecipeAsync">Add recipe</MudButton>
                                </MudItem>
                            </MudGrid>
                            @foreach (var pair in Options.Recipes.OrderBy(p => p.Key, StringComparer.Ordinal))
                            {
                                var recipeName = pair.Key;
                                var recipe = pair.Value;
                                <MudPaper Outlined="true" Class="pa-3 mb-2">
                                    <MudStack Spacing="2">
                                        <MudText Typo="Typo.subtitle1"><code>@recipeName</code> @(string.IsNullOrWhiteSpace(recipe.Label) ? "" : $"— {recipe.Label}")</MudText>
                                        @if (!string.IsNullOrWhiteSpace(recipe.Usage))
                                        {
                                            <MudText Typo="Typo.body2" Class="@Ui(NerdDesignSystemUi.MutedContent)">@recipe.Usage</MudText>
                                        }
                                        <MudStack Row="true" Spacing="2" Class="flex-wrap">
                                            <MudSelect T="string" Label="Surface" Value="@recipe.Surface" ValueChanged="@((string v) => UpdateRecipeAsync(recipeName, v, recipe.Content, recipe.Action, recipe.Label, recipe.Usage))">
                                                @foreach (var tokenName in TokenNames) { <MudSelectItem Value="@tokenName">@tokenName</MudSelectItem> }
                                            </MudSelect>
                                            <MudSelect T="string" Label="Content" Value="@recipe.Content" ValueChanged="@((string v) => UpdateRecipeAsync(recipeName, recipe.Surface, v, recipe.Action, recipe.Label, recipe.Usage))">
                                                @foreach (var tokenName in TokenNames) { <MudSelectItem Value="@tokenName">@tokenName</MudSelectItem> }
                                            </MudSelect>
                                            <MudSelect T="string" Label="Action" Value="@recipe.Action" ValueChanged="@((string? v) => UpdateRecipeAsync(recipeName, recipe.Surface, recipe.Content, v, recipe.Label, recipe.Usage))" Clearable="true">
                                                @foreach (var tokenName in TokenNames) { <MudSelectItem Value="@tokenName">@tokenName</MudSelectItem> }
                                            </MudSelect>
                                            <MudTextField Label="Label" Value="@recipe.Label" ValueChanged="@((string? v) => UpdateRecipeAsync(recipeName, recipe.Surface, recipe.Content, recipe.Action, v, recipe.Usage))" Immediate="true" />
                                            <MudTextField Label="Usage" Value="@recipe.Usage" ValueChanged="@((string? v) => UpdateRecipeAsync(recipeName, recipe.Surface, recipe.Content, recipe.Action, recipe.Label, v))" Immediate="true" />
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" OnClick="@(() => RemoveRecipeAsync(recipeName))" />
                                        </MudStack>
                                    </MudStack>
                                </MudPaper>
                            }
                            @if (PreviewRecipe is not null && PreviewValidation is not null)
                            {
                                <MudDivider Class="my-3" />
                                <MudText Typo="Typo.h6">Layout templates</MudText>
                                <NerdBrandPreviewTemplates Recipe="PreviewRecipe"
                                                           Validation="PreviewValidation"
                                                           Prefix="Options.Prefix"
                                                           RecipeName="@PreviewRecipeName" />
                            }
                        </MudPaper>
                        break;
                    case 5:
                        <MudPaper Outlined="true" Class="pa-4">
                            <MudText Typo="Typo.h6">Approved pairings</MudText>
                            <MudTextField Value="_pairingGuideName" ValueChanged="@((string value) => OnPairingGuideNameChanged(value))" Label="Pairing guide name" Class="mt-2 mb-3" Immediate="true" />
                            <MudStack Row="true" Spacing="2" Class="flex-wrap mb-3">
                                <MudSelect T="string" @bind-Value="_newPairingContent" Label="Content">
                                    @foreach (var tokenName in TokenNames) { <MudSelectItem Value="@tokenName">@tokenName</MudSelectItem> }
                                </MudSelect>
                                <MudSelect T="string" @bind-Value="_newPairingSurface" Label="Surface">
                                    @foreach (var tokenName in TokenNames) { <MudSelectItem Value="@tokenName">@tokenName</MudSelectItem> }
                                </MudSelect>
                                <MudButton Variant="Variant.Filled" Class="@Ui(NerdDesignSystemUi.BrandChrome)" OnClick="AddPairingAsync">Add pairing</MudButton>
                            </MudStack>
                            <MudSimpleTable Dense="true" Bordered="true" Hover="true">
                                <thead><tr><th>Content</th><th>Surface</th><th>WCAG</th><th></th></tr></thead>
                                <tbody>
                                    @foreach (var pairing in _approvedPairings.OrderBy(p => p.Surface).ThenBy(p => p.Content, StringComparer.Ordinal))
                                    {
                                        var validation = NerdTokenPairingTools.ValidatePairing(pairing.Content, pairing.Surface, Options);
                                        <tr>
                                            <td><code>@pairing.Content</code></td>
                                            <td><code>@pairing.Surface</code></td>
                                            <td>@(validation.MeetsAa ? "AA" : "Fail")</td>
                                            <td>
                                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                               OnClick="@(() => RemovePairingAsync(pairing))" />
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        </MudPaper>
                        break;
                    case 6:
                        <MudPaper Outlined="true" Class="pa-4" data-testid="workbook-theme-sets-panel">
                            <MudText Typo="Typo.h6">Theme sets</MudText>
                            <MudText Typo="Typo.body2" Class="@Ui(NerdDesignSystemUi.MutedContent)">
                                Light/dark overrides are exported in <code>themeSets</code> and merged into CSS on pack load.
                            </MudText>
                            <MudButton Variant="Variant.Outlined" Size="Size.Small" Class="mt-2" OnClick="RefreshThemeSetsAsync">
                                Refresh from palette
                            </MudButton>
                            @foreach (var set in ThemeSets.OrderBy(pair => pair.Key, StringComparer.Ordinal))
                            {
                                <MudText Typo="Typo.subtitle2" Class="mt-3">@(set.Value.DisplayName ?? set.Key) (@set.Value.Colors.Count overrides)</MudText>
                                <MudSimpleTable Dense="true" Bordered="true" Hover="true" Class="mt-1">
                                    <thead><tr><th>Token</th><th>Value</th></tr></thead>
                                    <tbody>
                                        @foreach (var color in set.Value.Colors.OrderBy(pair => pair.Key, StringComparer.Ordinal))
                                        {
                                            <tr data-testid="@($"workbook-theme-{set.Key}-{color.Key}")">
                                                <td><code>@color.Key</code></td>
                                                <td><code>@(color.Value.Value ?? color.Value.Dark ?? color.Value.Light)</code></td>
                                            </tr>
                                        }
                                    </tbody>
                                </MudSimpleTable>
                            }
                        </MudPaper>
                        break;
                    case 7:
                        <MudPaper Outlined="true" Class="pa-4" data-testid="workbook-spacing-panel">
                            <MudText Typo="Typo.h6">Spacing scale</MudText>
                            <MudText Typo="Typo.body2" Class="@Ui(NerdDesignSystemUi.MutedContent)">
                                Generate <code>space-*</code>, <code>pa-*</code>, and <code>ma-*</code> utilities from a base unit and ratio.
                            </MudText>
                            <MudGrid Spacing="2" Class="mt-3">
                                <MudItem xs="12" md="3">
                                    <MudNumericField @bind-Value="_spacingBaseUnit" Label="Base unit (px)" Min="1" Max="32" />
                                </MudItem>
                                <MudItem xs="12" md="3">
                                    <MudNumericField @bind-Value="_spacingRatio" Label="Ratio" Min="0.5" Max="3" Step="0.1" />
                                </MudItem>
                                <MudItem xs="12" md="3">
                                    <MudSelect T="NerdSpacingScaleCurve" @bind-Value="_spacingCurve" Label="Curve">
                                        <MudSelectItem Value="NerdSpacingScaleCurve.Linear">Linear</MudSelectItem>
                                        <MudSelectItem Value="NerdSpacingScaleCurve.Geometric">Geometric</MudSelectItem>
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" md="3" Class="d-flex align-end gap-2 flex-wrap">
                                    <MudButton Variant="Variant.Filled" Class="@Ui(NerdDesignSystemUi.BrandChrome)" OnClick="ApplySpacingScaleAsync">Apply scale</MudButton>
                                    <MudButton Variant="Variant.Outlined" OnClick="ApplyDefaultSpacingScaleAsync">Default 4px</MudButton>
                                </MudItem>
                            </MudGrid>
                            <MudSimpleTable Dense="true" Bordered="true" Hover="true" Class="mt-3">
                                <thead><tr><th>Step</th><th>Preview</th><th>Value</th></tr></thead>
                                <tbody>
                                    @foreach (var pair in PreviewSpacingScale.OrderBy(entry => entry.Key, StringComparer.Ordinal))
                                    {
                                        <tr data-testid="@($"workbook-spacing-{pair.Key}")">
                                            <td><code>@pair.Key</code></td>
                                            <td><span class="@($"{Options.Prefix}-pa-{pair.Key}")" style="display:inline-block;background:var(--mud-palette-lines-default);">@pair.Key</span></td>
                                            <td>@pair.Value</td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        </MudPaper>
                        break;
                    case 8:
                        <MudPaper Outlined="true" Class="pa-4" data-testid="workbook-transforms-panel">
                            <MudText Typo="Typo.h6">Derived transforms</MudText>
                            <MudGrid Spacing="2" Class="mt-2 mb-3">
                                <MudItem xs="12" md="3"><MudTextField @bind-Value="_newTransformName" Label="Token name" Immediate="true" /></MudItem>
                                <MudItem xs="12" md="3">
                                    <MudSelect T="string" @bind-Value="_newTransformSource" Label="Source token">
                                        @foreach (var tokenName in TokenNames) { <MudSelectItem Value="@tokenName">@tokenName</MudSelectItem> }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" md="2">
                                    <MudSelect T="string" @bind-Value="_newTransformOperation" Label="Operation">
                                        <MudSelectItem Value="@("lighten")">lighten</MudSelectItem>
                                        <MudSelectItem Value="@("darken")">darken</MudSelectItem>
                                        <MudSelectItem Value="@("alpha")">alpha</MudSelectItem>
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" md="2"><MudNumericField @bind-Value="_newTransformAmount" Label="Amount" Min="0" Max="1" Step="0.05" /></MudItem>
                                <MudItem xs="12" md="2" Class="d-flex align-end">
                                    <MudButton Variant="Variant.Filled" Class="@Ui(NerdDesignSystemUi.BrandChrome)" OnClick="AddTransformAsync">Add transform</MudButton>
                                </MudItem>
                            </MudGrid>
                            <MudSimpleTable Dense="true" Bordered="true" Hover="true">
                                <thead><tr><th>Token</th><th>Source</th><th>Operation</th><th>Preview</th><th></th></tr></thead>
                                <tbody>
                                    @foreach (var pair in Options.Transforms.OrderBy(entry => entry.Key, StringComparer.Ordinal))
                                    {
                                        var preview = Options.Colors.TryGetValue(pair.Key, out var token) ? token.Value : "—";
                                        <tr>
                                            <td><code>@pair.Key</code></td>
                                            <td><code>@pair.Value.Source</code></td>
                                            <td>@pair.Value.Operation (@pair.Value.Amount)</td>
                                            <td><code>@preview</code></td>
                                            <td><MudIconButton Icon="@Icons.Material.Filled.Delete" OnClick="@(() => RemoveTransformAsync(pair.Key))" /></td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        </MudPaper>
                        break;
                    case 9:
                        <MudPaper Outlined="true" Class="pa-4">
                            <MudStack Spacing="2">
                                <MudText Typo="Typo.h6">Export client pack</MudText>
                                <MudButton Variant="Variant.Filled" Class="@Ui(NerdDesignSystemUi.BrandChrome)" OnClick="DownloadPackJsonAsync">
                                    Download token-pack.json
                                </MudButton>
                                <MudButton Href="@Options.CatalogRoute" Variant="Variant.Outlined">Open colors catalog</MudButton>
                                <MudButton Href="@Options.RecipesCatalogRoute" Variant="Variant.Outlined">Open recipes catalog</MudButton>
                            </MudStack>
                        </MudPaper>
                        break;
                }

                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Outlined" Disabled="@(_activeStep == 0)" OnClick="@(() => _activeStep--)">Back</MudButton>
                    <MudButton Variant="Variant.Filled" Class="@Ui(NerdDesignSystemUi.BrandChrome)" Disabled="@(_activeStep >= ExportStepIndex)" OnClick="@(() => _activeStep++)">Next</MudButton>
                </MudStack>

                @if (_status is not null)
                {
                    <MudAlert Severity="_statusSeverity" Variant="Variant.Outlined" Dense="true">@_status</MudAlert>
                }
            </MudStack>
        </NerdCatalogPage>
    </NerdCatalogThemeProvider>
    }
}
