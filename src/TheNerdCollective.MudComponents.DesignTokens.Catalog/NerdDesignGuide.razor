@using TheNerdCollective.MudComponents.DesignTokens
@using TheNerdCollective.MudComponents.Shared

@if (!IsAvailable)
{
    <MudContainer MaxWidth="MaxWidth.Medium" Class="my-8">
        <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">
            Design guide is disabled or only available in Development.
        </MudAlert>
    </MudContainer>
}
else
{
    <NerdDesignSystemScripts />
    <NerdDesignTokenStyles />
    <NerdCatalogPage>
        <MudStack Spacing="4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="flex-wrap gap-3">
                <div>
                    <MudText Typo="Typo.h4">Design guide</MudText>
                    <MudText Typo="Typo.body2" Class="@Ui(NerdDesignSystemUi.MutedContent)">
                        Live brand manual for <strong>@(Options.ActiveBrandPackId ?? Options.Prefix)</strong>
                        @if (!string.IsNullOrWhiteSpace(Options.ActiveBrandIdentityVersion))
                        {
                            <span> · identity @Options.ActiveBrandIdentityVersion</span>
                        }
                        · Prefix <code>@Options.Prefix</code>
                    </MudText>
                </div>
                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="flex-wrap">
                    <MudSelect T="string" Value="_selectedBrand" ValueChanged="SwitchBrandAsync" Label="Brand" Style="min-width: 160px;">
                        @foreach (var brandPack in InstalledBrandPacks)
                        {
                            <MudSelectItem Value="@brandPack.Id">@NerdBrandPackLabels.Format(brandPack)</MudSelectItem>
                        }
                    </MudSelect>
                    <MudButton Href="@HubOptions.HubRoute" Variant="Variant.Text" Class="@Ui(NerdDesignSystemUi.MutedContent)">Design system</MudButton>
                    <MudButton Href="@HubOptions.PlayBookRoute" Variant="Variant.Text" Class="@Ui(NerdDesignSystemUi.MutedContent)">PlayBook</MudButton>
                </MudStack>
            </MudStack>

            <MudPaper Outlined="true" Class="pa-4">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="flex-wrap gap-3">
                    <div>
                        <MudText Typo="Typo.h6">Design-to-code parity</MudText>
                        <MudText Typo="Typo.body2" Class="@Ui(NerdDesignSystemUi.MutedContent)">
                            How closely runtime matches a complete brand manual (shell, recipes, pairings, defaults).
                        </MudText>
                    </div>
                    <MudProgressCircular Value="@_parity.Score" Size="Size.Large" Color="@ParityColor">
                        <MudText Typo="Typo.h6">@_parity.Score</MudText>
                    </MudProgressCircular>
                </MudStack>
                <MudGrid Spacing="2" Class="mt-3">
                    @foreach (var metric in _parity.Metrics)
                    {
                        <MudItem xs="12" sm="6" md="4">
                            <MudPaper Outlined="true" Class="pa-3">
                                <MudText Typo="Typo.subtitle2">@metric.Name</MudText>
                                <MudText Typo="Typo.caption" Class="@Ui(NerdDesignSystemUi.MutedContent)">@metric.Detail</MudText>
                                <MudProgressLinear Value="@metric.Score" Color="@(metric.Score >= 80 ? Color.Success : metric.Score >= 50 ? Color.Warning : Color.Error)" Class="mt-2" />
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
            </MudPaper>

            <MudPaper Outlined="true" Class="pa-4" data-testid="mud-state-parity-panel">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="flex-wrap gap-3">
                    <div>
                        <MudText Typo="Typo.h6">Mud state parity</MudText>
                        <MudText Typo="Typo.body2" Class="@Ui(NerdDesignSystemUi.MutedContent)">
                            Inventory-driven P1/P3 components — required state selectors in generated CSS for @Options.Prefix.
                        </MudText>
                    </div>
                    <MudProgressCircular Value="@_mudStateParity.Score" Size="Size.Large" Color="@MudStateParityColor">
                        <MudText Typo="Typo.h6">@_mudStateParity.Score</MudText>
                    </MudProgressCircular>
                </MudStack>
                <MudGrid Spacing="2" Class="mt-3">
                    @foreach (var component in _mudStateParity.Components)
                    {
                        <MudItem xs="12" sm="6" md="4">
                            <MudPaper Outlined="true"
                                      Class="pa-3"
                                      data-testid="@($"mud-parity-{component.Component}")">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.subtitle2">@component.Component</MudText>
                                    <MudChip T="string" Size="Size.Small" Color="@(component.Passes ? Color.Success : Color.Warning)">
                                        @component.Classification
                                    </MudChip>
                                </MudStack>
                                <MudText Typo="Typo.caption" Class="@Ui(NerdDesignSystemUi.MutedContent)">
                                    @component.Family · @component.Detail
                                </MudText>
                                <MudProgressLinear Value="@component.Score"
                                                   Color="@(component.Passes ? Color.Success : Color.Warning)"
                                                   Class="mt-2" />
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
            </MudPaper>

            <MudPaper Outlined="true" Class="pa-4" data-testid="mud-palette-fidelity-panel">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="flex-wrap gap-3">
                    <div>
                        <MudText Typo="Typo.h6">Mud palette fidelity</MudText>
                        <MudText Typo="Typo.body2" Class="@Ui(NerdDesignSystemUi.MutedContent)">
                            Palette-first reskin checks — brand root coverage, intent overrides, bridges-only semantics.
                        </MudText>
                    </div>
                    <MudProgressCircular Value="@_mudPaletteFidelity.Score" Size="Size.Large" Color="@MudPaletteFidelityColor">
                        <MudText Typo="Typo.h6">@_mudPaletteFidelity.Score</MudText>
                    </MudProgressCircular>
                </MudStack>
                <MudGrid Spacing="2" Class="mt-3">
                    @foreach (var check in _mudPaletteFidelity.Checks)
                    {
                        <MudItem xs="12" sm="6" md="4">
                            <MudPaper Outlined="true"
                                      Class="pa-3"
                                      data-testid="@($"mud-palette-{check.Name.Replace(' ', '-').ToLowerInvariant()}")">
                                <MudText Typo="Typo.subtitle2">@check.Name</MudText>
                                <MudText Typo="Typo.caption" Class="@Ui(NerdDesignSystemUi.MutedContent)">@check.Detail</MudText>
                                <MudProgressLinear Value="@check.Score"
                                                   Color="@(check.Score >= 80 ? Color.Success : check.Score >= 50 ? Color.Warning : Color.Error)"
                                                   Class="mt-2" />
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
            </MudPaper>

            <MudPaper Outlined="true" Class="pa-4" data-testid="component-family-map-panel">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="flex-wrap gap-3">
                    <div>
                        <MudText Typo="Typo.h6">Component family intent map</MudText>
                        <MudText Typo="Typo.body2" Class="@Ui(NerdDesignSystemUi.MutedContent)">
                            Framework-neutral parts mapped to semantic intents for MudBlazor.
                        </MudText>
                    </div>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">TS-034</MudChip>
                </MudStack>
                <MudSimpleTable Dense="true" Hover="true" Bordered="true" Class="mt-3">
                    <thead>
                        <tr>
                            <th>Family</th>
                            <th>Part</th>
                            <th>Intent</th>
                            <th>Mud selector</th>
                            <th>CSS variable</th>
                            <th>Sample</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var binding in _familyBindings)
                        {
                            <tr data-testid="@($"family-map-{binding.Family}-{binding.PartId}")">
                                <td><code>@binding.Family</code></td>
                                <td><code>@binding.PartId</code></td>
                                <td><code>@binding.IntentAlias</code></td>
                                <td><code>@(binding.MudSelectors.FirstOrDefault() ?? "—")</code></td>
                                <td><code>@binding.CssVariable</code></td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(binding.SampleColor))
                                    {
                                        <span data-testid="@($"family-swatch-{binding.Family}-{binding.PartId}")"
                                              style="display:inline-block;width:20px;height:20px;border-radius:4px;border:1px solid var(--mud-palette-lines-default);background:@binding.SampleColor"></span>
                                        <code class="ml-1">@binding.SampleColor</code>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
                <MudText Typo="Typo.caption" Class="@($"{Ui(NerdDesignSystemUi.MutedContent)} mt-2")">
                    Dogfood: <code>picker.day-selected</code> and generated <code>.mud-day.mud-selected</code> both resolve to
                    <code>@NerdComponentFamilyTools.ResolveCssVariable(Options, "primary-action")</code>.
                </MudText>
            </MudPaper>

            <MudPaper Outlined="true" Class="pa-4">
                <MudText Typo="Typo.h6">Color palette</MudText>
                <MudText Typo="Typo.caption" Class="@Ui(NerdDesignSystemUi.MutedContent)">
                    Brand tokens — use via semantic intents in markup, not raw names.
                </MudText>
                <MudGrid Spacing="2" Class="mt-2">
                    @foreach (var color in Options.Colors.OrderBy(pair => pair.Key, StringComparer.Ordinal))
                    {
                        <MudItem xs="6" sm="4" md="3" lg="2">
                            <MudPaper Outlined="true" Class="pa-2">
                                <div style="height: 48px; border-radius: 6px; background: @color.Value.Value;"></div>
                                <MudText Typo="Typo.caption" Class="mt-1"><code>@color.Key</code></MudText>
                                <MudText Typo="Typo.caption" Class="@Ui(NerdDesignSystemUi.MutedContent)">@color.Value.Value</MudText>
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
            </MudPaper>

            @if (HasApprovedPairings)
            {
                <MudPaper Outlined="true" Class="pa-4">
                    <MudText Typo="Typo.h6">@BrandGuideName godkendte par</MudText>
                    <MudGrid Spacing="2" Class="mt-2">
                        @foreach (var pair in ActivePairingPolicy!.GetApprovedPairings())
                        {
                            var validation = NerdTokenPairingTools.ValidatePairing(pair.Content, pair.Surface, Options);
                            <MudItem xs="12" sm="6" md="4" lg="3">
                                <NerdPairingSurface Validation="validation" Variant="NerdPairingSurfaceVariant.Swatch">
                                    <p class="nerd-pairing-swatch__title">@pair.Content on @pair.Surface</p>
                                    <p class="nerd-pairing-swatch__meta">WCAG @FormatRatio(validation.ContrastRatio)</p>
                                </NerdPairingSurface>
                            </MudItem>
                        }
                    </MudGrid>
                </MudPaper>
            }

            <NerdDesignTokenIntentPanel Options="Options" HubOptions="HubOptions" />

            <NerdDesignGuideBrandPreview />

            <NerdDesignGuideScenes TokenOptions="Options" />

            <MudPaper Outlined="true" Class="pa-4">
                <MudText Typo="Typo.h6">Typography</MudText>
                <MudText Typo="Typo.body2" Class="@Ui(NerdDesignSystemUi.MutedContent)">
                    Responsive roles and clamp scales live in the typography catalog.
                </MudText>
                <MudButton Href="@HubOptions.TypographyRoute" Variant="Variant.Outlined" Class="@($"{Ui(NerdDesignSystemUi.PrimaryAction)} mt-2")">
                    Open typography catalog
                </MudButton>
            </MudPaper>

            <NerdDesignHandoffExporter ClientId="@_clientId" DesignGuideUrl="@DesignGuideUrl" />
        </MudStack>
    </NerdCatalogPage>
}
