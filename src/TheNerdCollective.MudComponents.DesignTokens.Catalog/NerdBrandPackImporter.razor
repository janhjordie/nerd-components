@using Microsoft.AspNetCore.Components.Forms
@using TheNerdCollective.MudComponents.DesignTokens

<MudPaper Outlined="true" Class="pa-4">
    <MudStack Spacing="2">
        <MudText Typo="Typo.h6">Import brand pack</MudText>
        <MudText Typo="Typo.body2" Class="@Ui(NerdDesignSystemUi.MutedContent)">
            Upload <code>token-pack.json</code> (schema v2) to onboard a client brand without code changes.
        </MudText>
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="flex-wrap">
            <InputFile OnChange="OnImportAsync" accept=".json,application/json"
                       class="mud-button-root mud-button mud-button-outlined mud-ripple"
                       style="width:auto;padding:.375rem .75rem;" />
            @if (!string.IsNullOrWhiteSpace(_status))
            {
                <MudChip T="string" Color="@_statusColor" Variant="Variant.Outlined">@_status</MudChip>
            }
        </MudStack>
    </MudStack>
</MudPaper>

@code {
    [Parameter]
    public EventCallback<NerdTokenPack> OnImported { get; set; }

    [Parameter]
    public NerdDesignTokenOptions Options { get; set; } = default!;

    private string? _status;
    private Color _statusColor = Color.Default;

    private string Ui(string semanticAlias) =>
        NerdDesignSystemUi.TokenClass(Options.Prefix, semanticAlias);

    private async Task OnImportAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;
        if (file is null)
        {
            return;
        }

        await using var stream = file.OpenReadStream(maxAllowedSize: 2_000_000);
        using var reader = new StreamReader(stream);
        var json = await reader.ReadToEndAsync();
        var result = NerdTokenPackImporter.TryImport(json);
        _status = result.Message;
        _statusColor = result.Success ? Color.Success : Color.Error;

        if (result.Success && result.Pack is not null)
        {
            await OnImported.InvokeAsync(result.Pack);
        }
    }
}
