@using TheNerdCollective.MudComponents.Shared

<MudPaper Outlined="true" Class="pa-4" data-testid="design-token-intent-panel">
    <MudText Typo="Typo.h6">Intent snippets</MudText>
    <MudText Typo="Typo.body2" Class="@Ui(NerdDesignSystemUi.MutedContent)">
        Copy semantic alias usage for MudBlazor components and CSS classes.
    </MudText>

    <MudSimpleTable Dense="true" Hover="true" Bordered="true" Class="mt-3">
        <thead>
            <tr>
                <th>Alias</th>
                <th>Mud class</th>
                <th>Usage</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var snippet in IntentSnippets)
            {
                <tr data-testid="@($"intent-panel-{snippet.IntentAlias}")">
                    <td><code>@snippet.IntentAlias</code></td>
                    <td><code>.@Ui(snippet.IntentAlias)</code></td>
                    <td>@snippet.Usage</td>
                </tr>
            }
        </tbody>
    </MudSimpleTable>
</MudPaper>

@code {
    [Parameter, EditorRequired]
    public NerdDesignTokenOptions Options { get; set; } = default!;

    [Parameter]
    public NerdDesignSystemOptions HubOptions { get; set; } = default!;

    private static IReadOnlyList<NerdIntentUsageSnippets.NerdIntentUsageSnippet> IntentSnippets =>
        NerdIntentUsageSnippets.CoreIntents;

    private string Ui(string semanticAlias) =>
        NerdDesignSystemUi.TokenClass(Options.Prefix, semanticAlias);
}
