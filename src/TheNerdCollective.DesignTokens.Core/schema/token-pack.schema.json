{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Nerd design token pack",
  "type": "object",
  "required": ["clientId", "prefix", "version", "colors"],
  "properties": {
    "clientId": { "type": "string", "minLength": 1 },
    "brandId": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "displayName": { "type": "string", "minLength": 1 },
    "prefix": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "version": { "type": "integer", "minimum": 2 },
    "brandIdentityVersion": { "type": "string" },
    "pairingGuideName": { "type": "string" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "colors": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["value"],
        "properties": {
          "value": { "type": "string", "minLength": 1 },
          "light": { "type": "string" },
          "dark": { "type": "string" },
          "contrastText": { "type": "string" },
          "darkContrastText": { "type": "string" },
          "description": { "type": "string" },
          "roles": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    },
    "aliases": { "type": "object", "additionalProperties": { "type": "string" } },
    "radii": { "type": "object", "additionalProperties": { "type": "string" } },
    "shadows": { "type": "object", "additionalProperties": { "type": "string" } },
    "spacing": { "type": "object", "additionalProperties": { "type": "string" } },
    "breakpoints": { "type": "object", "additionalProperties": { "type": "string" } },
    "motionDurations": { "type": "object", "additionalProperties": { "type": "string" } },
    "motionEasings": { "type": "object", "additionalProperties": { "type": "string" } },
    "zIndex": { "type": "object", "additionalProperties": { "type": "string" } },
    "transforms": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["source", "operation"],
        "properties": {
          "source": { "type": "string" },
          "operation": { "type": "string" },
          "amount": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "additionalProperties": false
      }
    },
    "recipes": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["surface", "content"],
        "properties": {
          "surface": { "type": "string" },
          "content": { "type": "string" },
          "action": { "type": "string" },
          "border": { "type": "string" },
          "label": { "type": "string" },
          "usage": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "approvedPairings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["content", "surface"],
        "properties": {
          "content": { "type": "string" },
          "surface": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "lockedTokens": {
      "type": "array",
      "items": { "type": "string" }
    },
    "opacities": { "type": "object" },
    "themeSets": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "displayName": { "type": "string" },
          "colors": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    },
    "shell": {
      "type": "object",
      "properties": {
        "appBar": { "$ref": "#/$defs/shellSlot" },
        "drawer": { "$ref": "#/$defs/shellSlot" },
        "navMenu": { "$ref": "#/$defs/shellSlot" },
        "main": { "$ref": "#/$defs/shellSlot" }
      },
      "additionalProperties": false
    },
    "frameworkDefaults": {
      "type": "object",
      "properties": {
        "mudblazor": {
          "type": "object",
          "properties": {
            "palette": {
              "type": "object",
              "properties": {
                "primary": { "type": "string" },
                "secondary": { "type": "string" },
                "tertiary": { "type": "string" },
                "info": { "type": "string" },
                "success": { "type": "string" },
                "warning": { "type": "string" },
                "error": { "type": "string" },
                "dark": { "type": "string" },
                "surface": { "type": "string" },
                "background": { "type": "string" },
                "textPrimary": { "type": "string" },
                "textSecondary": { "type": "string" },
                "textDisabled": { "type": "string" },
                "actionDefault": { "type": "string" },
                "actionDisabled": { "type": "string" },
                "appbarBackground": { "type": "string" },
                "appbarText": { "type": "string" },
                "drawerBackground": { "type": "string" },
                "drawerText": { "type": "string" },
                "drawerIcon": { "type": "string" },
                "linesDefault": { "type": "string" },
                "linesInputs": { "type": "string" }
              },
              "additionalProperties": false
            },
            "button": {
              "type": "object",
              "properties": {
                "filled": { "type": "string" },
                "outlined": { "type": "string" },
                "text": { "type": "string" }
              },
              "additionalProperties": false
            },
            "textField": { "$ref": "#/$defs/componentIntent" },
            "datePicker": { "$ref": "#/$defs/componentIntent" },
            "navLink": {
              "type": "object",
              "properties": {
                "default": { "type": "string" },
                "active": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "shellSlot": {
      "type": "object",
      "oneOf": [
        { "required": ["alias"], "properties": { "alias": { "type": "string" } }, "additionalProperties": false },
        { "required": ["recipe"], "properties": { "recipe": { "type": "string" } }, "additionalProperties": false }
      ]
    },
    "componentIntent": {
      "type": "object",
      "properties": {
        "intent": { "type": "string" },
        "popover": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
