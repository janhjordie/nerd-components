@if (!IsAvailable)
{
    <MudContainer MaxWidth="MaxWidth.Medium" Class="my-8">
        <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">
            Responsive typography catalog is disabled or only available in Development.
        </MudAlert>
    </MudContainer>
}
else
{
    <NerdDesignSystemScripts />
    <NerdCatalogThemeProvider Theme="_previewTheme" IsDarkMode="false">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="my-6">
            <MudStack Spacing="4">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="flex-wrap gap-3">
                    <div>
                        <MudText Typo="Typo.h4">Responsive typography</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            CSS <code>clamp()</code> through <code>MudTheme.Typography</code> — no JS, no viewport service.
                        </MudText>
                    </div>
                    <MudStack Row="true" Spacing="1" Class="flex-wrap">
                        <MudButton Href="@HubOptions.HubRoute" Variant="Variant.Text">Design system</MudButton>
                        <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined">@Options.CatalogRoute</MudChip>
                    </MudStack>
                </MudStack>

                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="flex-wrap">
                    <MudSwitch @bind-Value="_showAllRoles" Label="Show all roles" />
                    <MudText Typo="Typo.caption">Viewport @_viewportWidth.ToString("0")px</MudText>
                    <MudSlider @bind-Value="_viewportWidth" Min="320" Max="1920" Step="10" Style="max-width: 320px;" />
                </MudStack>

                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="flex-wrap">
                    <MudTextField @bind-Value="_clientId" Label="ClientId" Immediate="true" />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveClientPackAsync">
                        Gem som klient
                    </MudButton>
                    @if (_saveStatus is not null)
                    {
                        <MudChip T="string" Color="Color.Success" Variant="Variant.Outlined">@_saveStatus</MudChip>
                    }
                </MudStack>

                <MudPaper Outlined="true" Class="pa-4">
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.h6">Live clamp editor</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            Tune minimum, preferred viewport value and maximum without changing the configured preset.
                        </MudText>
                        <MudSlider @bind-Value="_editorMinimum" Min="8" Max="64" Step="1" Immediate="true">
                            Minimum @_editorMinimum.ToString("0.#")px
                        </MudSlider>
                        <MudSlider @bind-Value="_editorPreferred" Min="0.5" Max="8" Step="0.1" Immediate="true">
                            Preferred @_editorPreferred.ToString("0.#")vw
                        </MudSlider>
                        <MudSlider @bind-Value="_editorMaximum" Min="16" Max="96" Step="1" Immediate="true">
                            Maximum @_editorMaximum.ToString("0.#")px
                        </MudSlider>
                        <MudText Typo="Typo.h5" Style="@($"font-size:{EditorClamp}")">
                            Live typography preview
                        </MudText>
                        <code>@EditorClamp</code>
                    </MudStack>
                </MudPaper>

                @if (_warnings.Count > 0)
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Filled">
                        <MudText Typo="Typo.subtitle2" Class="mb-2">
                            @_warnings.Count WCAG @Options.WcagVersion typography warning@(_warnings.Count == 1 ? "" : "s")
                        </MudText>
                        <MudStack Spacing="1">
                            @foreach (var warning in _warnings)
                            {
                                <MudText Typo="Typo.body2">
                                    <strong>@warning.Role</strong> (<code>@warning.FontSize</code>): @warning.Message
                                </MudText>
                            }
                        </MudStack>
                    </MudAlert>
                }

                <MudPaper Outlined="true" Class="pa-4">
                    <MudStack Spacing="3">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="flex-wrap gap-2">
                            <div>
                                <MudText Typo="Typo.h6">Device frames</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    Same sample at phone / tablet / desktop — no browser resize needed.
                                </MudText>
                            </div>
                            <MudSelect T="string" @bind-Value="_deviceSampleRole" Label="Sample role" Style="max-width: 220px;">
                                @foreach (var role in VisibleRoles)
                                {
                                    <MudSelectItem Value="@role.Role">@role.Role</MudSelectItem>
                                }
                            </MudSelect>
                        </MudStack>

                        @{
                            var sampleRole = GetRole(_deviceSampleRole);
                        }
                        @if (sampleRole is not null)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                <code>@sampleRole.FontSize</code>
                                @if (!string.IsNullOrWhiteSpace(DeviceSampleSnippet))
                                {
                                    <text> · </text>
                                    <NerdClipboardButton Text="@DeviceSampleSnippet" Label="Copy Razor" />
                                }
                            </MudText>

                            <MudStack Row="true" Spacing="3" Class="flex-wrap" AlignItems="AlignItems.Start">
                                @foreach (var device in DeviceFrames)
                                {
                                    <MudPaper Outlined="true" Class="pa-3" Style="@($"width:min(100%,{Math.Min(device.Width, 420)}px)")">
                                        <MudStack Spacing="2">
                                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@device.Label</MudChip>
                                                <MudText Typo="Typo.caption">@device.Width.ToString("0")px · @GetComputedSize(sampleRole, device.Width)</MudText>
                                            </MudStack>
                                            <div style="@($"width:{device.Width}px;max-width:100%;overflow:hidden;border:1px dashed var(--mud-palette-lines-default);padding:0.75rem;")">
                                                <MudText Typo="@sampleRole.Typo" Style="@($"font-size:{GetComputedSize(sampleRole, device.Width)}")">
                                                    The quick brown fox — @device.Label
                                                </MudText>
                                            </div>
                                        </MudStack>
                                    </MudPaper>
                                }
                            </MudStack>
                        }
                    </MudStack>
                </MudPaper>

                <MudPaper Outlined="true" Class="pa-4">
                    <MudStack Spacing="2">
                        <div>
                            <MudText Typo="Typo.h6">Breakpoint comparison</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Computed pixel sizes from <code>clamp()</code> at common viewports.
                            </MudText>
                        </div>
                        <MudTable Items="VisibleRoles.ToList()" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Style="overflow-x:auto;">
                            <HeaderContent>
                                <MudTh>Role</MudTh>
                                <MudTh>clamp()</MudTh>
                                @foreach (var width in BreakpointColumns)
                                {
                                    <MudTh>@width.ToString("0")</MudTh>
                                }
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Role"><strong>@context.Role</strong></MudTd>
                                <MudTd DataLabel="clamp()"><code style="font-size:0.75rem;">@context.FontSize</code></MudTd>
                                @foreach (var width in BreakpointColumns)
                                {
                                    <MudTd DataLabel="@($"{width}px")">@GetComputedSize(context, width)</MudTd>
                                }
                            </RowTemplate>
                        </MudTable>
                    </MudStack>
                </MudPaper>

                <MudPaper Outlined="true" Class="pa-4">
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.h6">Type scale curve</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            Relative role sizes at the selected viewport, with a 320px baseline.
                        </MudText>
                        @foreach (var role in VisibleRoles)
                        {
                            var current = NerdClampEvaluator.EvaluateAtViewport(role.FontSize, _viewportWidth) ?? 0;
                            var baseline = NerdClampEvaluator.EvaluateAtViewport(role.FontSize, 320) ?? 0;
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudText Style="width:80px">@role.Role</MudText>
                                <div style="flex:1;background:var(--mud-palette-background-grey);height:10px;border-radius:5px;">
                                    <div style="@($"width:{Math.Clamp(current / 72d * 100d, 2d, 100d):0.#}%;height:10px;border-radius:5px;background:var(--mud-palette-primary);")"></div>
                                </div>
                                <MudText Typo="Typo.caption" Style="width:150px">
                                    @baseline.ToString("0.#")px → @current.ToString("0.#")px
                                </MudText>
                            </MudStack>
                        }
                    </MudStack>
                </MudPaper>

                <MudText Typo="Typo.h6">Role previews</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Live preview constrained to the viewport slider (@_viewportWidth.ToString("0")px).
                </MudText>

                @foreach (var role in VisibleRoles)
                {
                    var accessibility = GetAccessibility(role.Role);

                    <MudPaper Outlined="true" Class="pa-4">
                        <MudStack Spacing="2">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="flex-wrap gap-2">
                                <MudText Typo="Typo.h6">@role.Role</MudText>
                                <MudStack Row="true" Spacing="1" Class="flex-wrap">
                                    @if (Options.Typography.ConfiguredRoles.Contains(role.Role))
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">configured</MudChip>
                                    }
                                    <NerdClipboardButton Text="@role.FontSize" Label="Copy CSS" />
                                    <NerdClipboardButton Text="@BuildRazorSnippet(role)" Label="Copy Razor" />
                                    @if (accessibility is not null)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="@(accessibility.MeetsResizeGuidance ? Color.Success : Color.Error)" Variant="Variant.Filled">
                                            WCAG @accessibility.WcagVersion resize @(accessibility.MeetsResizeGuidance ? "pass" : "fail")
                                        </MudChip>
                                        <MudChip T="string" Size="Size.Small" Color="@(accessibility.MeetsMinimumSize ? Color.Success : Color.Warning)" Variant="Variant.Outlined">
                                            Min @(accessibility.MinimumPixels?.ToString("0.#") ?? "?")px
                                        </MudChip>
                                        <MudChip T="string" Size="Size.Small" Color="@(accessibility.MeetsLineHeightGuidance ? Color.Success : Color.Warning)" Variant="Variant.Outlined">
                                            Line-height @(accessibility.MeetsLineHeightGuidance ? "pass" : "fail")
                                        </MudChip>
                                    }
                                </MudStack>
                            </MudStack>

                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                <code>@role.FontSize</code> · computed @GetComputedSize(role) at @_viewportWidth.ToString("0")px
                                · phone @GetComputedSize(role, 375) · tablet @GetComputedSize(role, 768) · desktop @GetComputedSize(role, 1440)
                            </MudText>

                            <MudPaper Class="pa-4" Outlined="true" Style="@($"max-width:{_viewportWidth}px")">
                                <MudText Typo="@role.Typo" Style="@($"font-size:{GetComputedSize(role)}")">
                                    The quick brown fox jumps over the lazy dog — @role.Role preview
                                </MudText>
                            </MudPaper>
                        </MudStack>
                    </MudPaper>
                }
            </MudStack>
        </MudContainer>
    </NerdCatalogThemeProvider>
}
