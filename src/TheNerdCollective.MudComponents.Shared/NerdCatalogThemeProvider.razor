@using MudBlazor

<MudThemeProvider Theme="@EffectiveTheme" IsDarkMode="@IsDarkMode" />
@ChildContent

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public MudTheme? Theme { get; set; }
    [Parameter] public bool IsDarkMode { get; set; }

    private MudTheme EffectiveTheme => Theme ?? new MudTheme();
}
