@if (!IsAvailable)
{
    <MudContainer MaxWidth="MaxWidth.Medium" Class="my-8">
        <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">
            Design system hub is disabled or only available in Development.
        </MudAlert>
    </MudContainer>
}
else
{
    <MudContainer MaxWidth="MaxWidth.Medium" Class="my-8">
        <MudStack Spacing="3">
            <MudText Typo="Typo.h4">Nerd design system</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Browse customer tokens, responsive typography, and the MudBlazor PlayBook.
            </MudText>
            <MudButton Href="@Options.DesignTokensRoute" Variant="Variant.Filled" Color="Color.Primary">
                Design tokens
            </MudButton>
            <MudButton Href="@Options.TypographyRoute" Variant="Variant.Outlined" Color="Color.Primary">
                Responsive typography
            </MudButton>
            <MudButton Href="@Options.PlayBookRoute" Variant="Variant.Outlined" Color="Color.Secondary">
                MudBlazor PlayBook
            </MudButton>
        </MudStack>
    </MudContainer>
}
