@inject NerdClipboardService Clipboard
@inject NerdDesignSystemOptions HubOptions

<MudButton Size="Size.Small"
           Variant="Variant.Outlined"
           Class="@IntentClass"
           OnClick="CopyAsync"
           ClickPropagation="false">
    @Label
</MudButton>

@code {
    [Parameter, EditorRequired]
    public string Text { get; set; } = string.Empty;

    [Parameter]
    public string Label { get; set; } = "Copy";

    [Parameter]
    public string Intent { get; set; } = NerdDesignSystemUi.PrimaryAction;

    private string IntentClass =>
        NerdDesignSystemUi.TokenClass(HubOptions, Intent);

    private async Task CopyAsync() => await Clipboard.CopyAsync(Text);
}
